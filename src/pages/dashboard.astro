---
// src/pages/dashboard.astro
import "../styles/global.css";
import { brandProjectStats } from "../data/projects";

const baseUrl =
	import.meta.env.BASE_URL === "/"
		? ""
		: import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>OrPiRa | Dashboard de Mensajes</title>
		<link rel="icon" type="image/png" href={`${baseUrl}/opr.png`} />
		<script>
			if (
				localStorage.theme === "dark" ||
				(!("theme" in localStorage) &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>

	<body
		class="bg-zinc-50 dark:bg-zinc-900 text-zinc-900 dark:text-white font-sans min-h-screen"
	>
		<!-- Login -->
		<div
			id="login-section"
			class="flex items-center justify-center min-h-screen"
		>
			<div
				class="max-w-sm w-full mx-4 p-8 bg-white dark:bg-zinc-800 rounded-2xl shadow-lg"
			>
				<h1
					class="text-2xl font-serif font-bold text-center text-brand.accent mb-6"
				>
					🔐 Dashboard OrPiRa
				</h1>
				<form id="login-form" class="space-y-4">
					<div>
						<label for="login-email" class="block text-sm font-medium mb-1"
							>Email</label
						>
						<input
							type="email"
							id="login-email"
							required
							placeholder="tu@email.com"
							class="w-full px-4 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition"
						/>
					</div>
					<div>
						<label for="login-password" class="block text-sm font-medium mb-1"
							>Contraseña</label
						>
						<input
							type="password"
							id="login-password"
							required
							placeholder="••••••••"
							class="w-full px-4 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition"
						/>
					</div>
					<button
						type="submit"
						id="login-btn"
						class="w-full py-3 px-6 bg-zinc-900 hover:bg-zinc-800 dark:bg-white dark:hover:bg-zinc-200 text-white dark:text-zinc-900 font-semibold rounded-lg transition-colors disabled:opacity-50"
					>
						Iniciar sesión
					</button>
					<p id="login-error" class="hidden text-center text-sm text-red-500">
					</p>
				</form>
				<p class="text-center text-xs text-gray-500 dark:text-gray-300 mt-4">
					<a href={`${baseUrl}/`} class="underline hover:text-brand.accent"
						>← Volver al portfolio</a
					>
				</p>
			</div>
		</div>

		<!-- Dashboard -->
		<div id="dashboard-section" class="hidden">
			<header
				class="bg-white dark:bg-zinc-800 shadow px-6 py-4 flex justify-between items-center"
			>
				<div class="flex items-center gap-3">
					<h1 class="text-xl font-serif font-bold text-brand.accent">
						📬 Mensajes recibidos
					</h1>
					<span
						id="msg-count"
						class="text-xs bg-orange-500 text-white px-2 py-0.5 rounded-full"
						>0</span
					>
				</div>
				<div class="flex items-center gap-3">
					<select
						id="filter-status"
						class="text-sm px-3 py-1.5 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-white"
					>
						<option value="todos">Todos</option>
						<option value="nuevo">🟢 Nuevos</option>
						<option value="leído">🔵 Leídos</option>
						<option value="respondido">✅ Respondidos</option>
						<option value="archivado">📁 Archivados</option>
					</select>
					<button
						id="logout-btn"
						class="text-sm px-4 py-1.5 border border-zinc-300 dark:border-zinc-700 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-700 transition"
					>
						Cerrar sesión
					</button>
				</div>
			</header>

			<!-- Stats -->
			<div
				class="max-w-6xl mx-auto px-6 py-6 grid grid-cols-2 md:grid-cols-4 gap-4"
			>
				<div
					class="bg-white dark:bg-zinc-800 rounded-xl p-4 text-center shadow-sm"
				>
					<p class="text-2xl font-bold" id="stat-total">0</p>
					<p class="text-xs text-gray-500 dark:text-gray-300">Total</p>
				</div>
				<div
					class="bg-white dark:bg-zinc-800 rounded-xl p-4 text-center shadow-sm"
				>
					<p class="text-2xl font-bold text-green-500" id="stat-nuevo">0</p>
					<p class="text-xs text-gray-500 dark:text-gray-300">Nuevos</p>
				</div>
				<div
					class="bg-white dark:bg-zinc-800 rounded-xl p-4 text-center shadow-sm"
				>
					<p class="text-2xl font-bold text-blue-500" id="stat-leido">0</p>
					<p class="text-xs text-gray-500 dark:text-gray-300">Leídos</p>
				</div>
				<div
					class="bg-white dark:bg-zinc-800 rounded-xl p-4 text-center shadow-sm"
				>
					<p class="text-2xl font-bold text-orange-500" id="stat-respondido">
						0
					</p>
					<p class="text-xs text-gray-500 dark:text-gray-300">Respondidos</p>
				</div>
			</div>

			<div class="max-w-6xl mx-auto px-6 pb-6">
				<div class="bg-white dark:bg-zinc-800 rounded-2xl shadow-sm p-5 md:p-6">
					<div class="flex flex-wrap items-center justify-between gap-3">
						<div>
							<h2 class="text-lg md:text-xl font-semibold text-brand.accent">
								📈 Métricas de Marca y SEO
							</h2>
							<p class="text-xs text-zinc-500 dark:text-zinc-300 mt-1">
								Tracking local de visitas + estado del ecosistema de proyectos.
							</p>
						</div>
						<button
							id="brand-metrics-refresh"
							class="text-xs uppercase tracking-[0.14em] px-3 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-100 dark:hover:bg-zinc-700 transition"
						>
							Actualizar métricas
						</button>
					</div>

					<div class="mt-5 grid grid-cols-2 md:grid-cols-4 gap-4">
						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 p-4"
						>
							<p class="text-xs text-zinc-500 dark:text-zinc-300">
								Vistas acumuladas
							</p>
							<p id="brand-views-total" class="text-2xl font-bold mt-1">0</p>
						</div>
						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 p-4"
						>
							<p class="text-xs text-zinc-500 dark:text-zinc-300">
								Sesiones únicas
							</p>
							<p id="brand-sessions-total" class="text-2xl font-bold mt-1">0</p>
						</div>
						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 p-4"
						>
							<p class="text-xs text-zinc-500 dark:text-zinc-300">
								Vistas últimos 7 días
							</p>
							<p id="brand-views-7d" class="text-2xl font-bold mt-1">0</p>
						</div>
						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 p-4"
						>
							<p class="text-xs text-zinc-500 dark:text-zinc-300">
								Página más vista
							</p>
							<p
								id="brand-top-page"
								class="text-sm font-semibold mt-2 truncate"
							>
								--
							</p>
						</div>
					</div>

					<div class="mt-6 grid md:grid-cols-[1.25fr_0.75fr] gap-4">
						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 overflow-hidden"
						>
							<div
								class="px-4 py-3 border-b border-zinc-200 dark:border-zinc-700"
							>
								<h3 class="text-sm font-semibold">Top páginas visitadas</h3>
							</div>
							<table class="w-full text-sm">
								<thead>
									<tr
										class="text-left text-xs uppercase tracking-[0.08em] text-zinc-500 dark:text-zinc-300"
									>
										<th class="px-4 py-2">Ruta</th>
										<th class="px-4 py-2">Vistas</th>
									</tr>
								</thead>
								<tbody id="brand-paths-body">
									<tr>
										<td
											colspan="2"
											class="px-4 py-4 text-zinc-500 dark:text-zinc-300"
										>
											Sin datos todavía.
										</td>
									</tr>
								</tbody>
							</table>
						</div>

						<div
							class="rounded-xl border border-zinc-200 dark:border-zinc-700 p-4 space-y-4"
						>
							<div>
								<p
									class="text-xs uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-300"
								>
									Ecosistema
								</p>
								<p class="text-2xl font-bold mt-1">{brandProjectStats.total}</p>
								<p class="text-xs text-zinc-500 dark:text-zinc-300">
									proyectos en roadmap de marca
								</p>
							</div>
							<div class="grid grid-cols-2 gap-3 text-sm">
								<div class="rounded-lg bg-zinc-100 dark:bg-zinc-900 p-3">
									<p class="text-zinc-500 dark:text-zinc-300 text-xs">
										Activos
									</p>
									<p class="font-semibold">{brandProjectStats.live}</p>
								</div>
								<div class="rounded-lg bg-zinc-100 dark:bg-zinc-900 p-3">
									<p class="text-zinc-500 dark:text-zinc-300 text-xs">
										Roadmap
									</p>
									<p class="font-semibold">{brandProjectStats.roadmap}</p>
								</div>
							</div>
							<p class="text-xs text-zinc-500 dark:text-zinc-300">
								SEO técnico base: canonical + OG + Twitter configurados en
								layouts.
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Tabla de mensajes -->
			<div class="max-w-6xl mx-auto px-6 pb-12">
				<div
					class="bg-white dark:bg-zinc-800 rounded-xl shadow-sm overflow-hidden"
				>
					<table class="w-full text-sm">
						<thead>
							<tr
								class="border-b border-zinc-200 dark:border-zinc-700 text-left"
							>
								<th class="px-4 py-3 font-medium">Estado</th>
								<th class="px-4 py-3 font-medium">Nombre</th>
								<th class="px-4 py-3 font-medium hidden md:table-cell">Email</th
								>
								<th class="px-4 py-3 font-medium hidden lg:table-cell"
									>Mensaje</th
								>
								<th class="px-4 py-3 font-medium">Fecha</th>
								<th class="px-4 py-3 font-medium">Acciones</th>
							</tr>
						</thead>
						<tbody id="messages-body">
							<tr>
								<td
									colspan="6"
									class="px-4 py-8 text-center text-gray-500 dark:text-gray-300"
								>
									Cargando mensajes...
								</td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>

			<!-- Modal detalle -->
			<div
				id="msg-modal"
				class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4"
			>
				<div
					class="bg-white dark:bg-zinc-800 rounded-2xl max-w-lg w-full p-6 relative max-h-[80vh] overflow-y-auto"
				>
					<button
						id="modal-close"
						class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 dark:hover:text-white text-xl"
						>✕</button
					>
					<h3 id="modal-name" class="text-lg font-bold mb-1"></h3>
					<p
						id="modal-email"
						class="text-sm text-gray-500 dark:text-gray-300 mb-1"
					>
					</p>
					<p
						id="modal-date"
						class="text-xs text-gray-400 dark:text-gray-300 mb-4"
					>
					</p>
					<div
						id="modal-message"
						class="bg-zinc-50 dark:bg-zinc-900 p-4 rounded-lg whitespace-pre-wrap text-sm mb-4"
					>
					</div>
					<div class="flex gap-2 flex-wrap">
						<button
							data-action="leído"
							class="modal-status-btn px-3 py-1.5 text-xs rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 hover:opacity-80"
							>🔵 Marcar leído</button
						>
						<button
							data-action="respondido"
							class="modal-status-btn px-3 py-1.5 text-xs rounded-lg bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 hover:opacity-80"
							>✅ Respondido</button
						>
						<button
							data-action="archivado"
							class="modal-status-btn px-3 py-1.5 text-xs rounded-lg bg-gray-100 dark:bg-gray-900/30 text-gray-700 dark:text-gray-300 hover:opacity-80"
							>📁 Archivar</button
						>
					</div>
				</div>
			</div>
		</div>

		<script>
			import { createClient } from "@supabase/supabase-js";

			const SUPABASE_URL = "https://wdaayllemxoubseukcxm.supabase.co";
			const SUPABASE_ANON_KEY =
				"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndkYWF5bGxlbXhvdWJzZXVrY3htIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ3MzQ1MzEsImV4cCI6MjA5MDMxMDUzMX0.4dcBlfEyoajW9nfi5ap0WfruV0yL0cNaWVqXmmO4PFo";
			const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

			// === Elementos del DOM ===
			const loginSection = document.getElementById("login-section")!;
			const dashboardSection = document.getElementById("dashboard-section")!;
			const loginForm = document.getElementById(
				"login-form",
			) as HTMLFormElement;
			const loginError = document.getElementById("login-error")!;
			const logoutBtn = document.getElementById("logout-btn")!;
			const messagesBody = document.getElementById("messages-body")!;
			const msgCount = document.getElementById("msg-count")!;
			const filterStatus = document.getElementById(
				"filter-status",
			) as HTMLSelectElement;
			const modal = document.getElementById("msg-modal")!;
			const modalClose = document.getElementById("modal-close")!;
			const modalName = document.getElementById("modal-name")!;
			const modalEmail = document.getElementById("modal-email")!;
			const modalDate = document.getElementById("modal-date")!;
			const modalMessage = document.getElementById("modal-message")!;

			// Stats
			const statTotal = document.getElementById("stat-total")!;
			const statNuevo = document.getElementById("stat-nuevo")!;
			const statLeido = document.getElementById("stat-leido")!;
			const statRespondido = document.getElementById("stat-respondido")!;

			const brandViewsTotal = document.getElementById("brand-views-total")!;
			const brandSessionsTotal = document.getElementById(
				"brand-sessions-total",
			)!;
			const brandViews7d = document.getElementById("brand-views-7d")!;
			const brandTopPage = document.getElementById("brand-top-page")!;
			const brandPathsBody = document.getElementById("brand-paths-body")!;
			const brandMetricsRefresh = document.getElementById(
				"brand-metrics-refresh",
			) as HTMLButtonElement | null;

			type BrandView = {
				path?: string;
				at?: string;
				sessionId?: string;
			};

			type BrandSession = {
				id?: string;
				startedAt?: string;
			};

			type BrandMetricsStore = {
				views: BrandView[];
				sessions: BrandSession[];
			};

			const BRAND_METRICS_KEY = "orpira_brand_metrics_v1";

			let currentMsgId: string | null = null;

			const statusEmoji: Record<string, string> = {
				nuevo: "🟢",
				leído: "🔵",
				respondido: "✅",
				archivado: "📁",
			};

			// === Auth ===
			async function checkSession() {
				const { data } = await supabase.auth.getSession();
				if (data.session) {
					showDashboard();
				}
			}

			loginForm.addEventListener("submit", async (e) => {
				e.preventDefault();
				const email = (
					document.getElementById("login-email") as HTMLInputElement
				).value;
				const password = (
					document.getElementById("login-password") as HTMLInputElement
				).value;
				const loginBtn = document.getElementById(
					"login-btn",
				) as HTMLButtonElement;

				loginBtn.disabled = true;
				loginBtn.textContent = "Verificando...";
				loginError.classList.add("hidden");

				const { error } = await supabase.auth.signInWithPassword({
					email,
					password,
				});

				if (error) {
					loginError.textContent = "❌ Credenciales incorrectas";
					loginError.classList.remove("hidden");
					loginBtn.disabled = false;
					loginBtn.textContent = "Iniciar sesión";
				} else {
					showDashboard();
				}
			});

			logoutBtn.addEventListener("click", async () => {
				await supabase.auth.signOut();
				loginSection.classList.remove("hidden");
				dashboardSection.classList.add("hidden");
			});

			// === Dashboard ===
			function showDashboard() {
				loginSection.classList.add("hidden");
				dashboardSection.classList.remove("hidden");
				renderBrandMetrics();
				loadMessages();
			}

			function getBrandMetrics(): BrandMetricsStore {
				try {
					const raw = localStorage.getItem(BRAND_METRICS_KEY);
					if (!raw) {
						return { views: [], sessions: [] };
					}
					const parsed = JSON.parse(raw);
					return {
						views: Array.isArray(parsed?.views) ? parsed.views : [],
						sessions: Array.isArray(parsed?.sessions) ? parsed.sessions : [],
					};
				} catch {
					return { views: [], sessions: [] };
				}
			}

			function renderBrandMetrics() {
				const { views, sessions } = getBrandMetrics();
				const now = Date.now();
				const sevenDaysMs = 7 * 24 * 60 * 60 * 1000;

				const validViews = views.filter(
					(view) => typeof view.path === "string",
				);
				const viewsLast7d = validViews.filter((view) => {
					if (!view.at) return false;
					const timestamp = new Date(view.at).getTime();
					if (Number.isNaN(timestamp)) return false;
					return now - timestamp <= sevenDaysMs;
				}).length;

				const uniqueSessionIds = new Set(
					validViews
						.map((view) => view.sessionId)
						.filter((sessionId): sessionId is string => Boolean(sessionId)),
				);
				const sessionCount = Math.max(uniqueSessionIds.size, sessions.length);

				const pathMap: Record<string, number> = {};
				validViews.forEach((view) => {
					const path = view.path || "/";
					pathMap[path] = (pathMap[path] || 0) + 1;
				});

				const topPaths = Object.entries(pathMap)
					.sort((a, b) => b[1] - a[1])
					.slice(0, 5);

				brandViewsTotal.textContent = String(validViews.length);
				brandSessionsTotal.textContent = String(sessionCount);
				brandViews7d.textContent = String(viewsLast7d);
				brandTopPage.textContent = topPaths.length > 0 ? topPaths[0][0] : "--";

				if (topPaths.length === 0) {
					brandPathsBody.innerHTML = `
						<tr>
							<td colspan="2" class="px-4 py-4 text-zinc-500 dark:text-zinc-300">Sin datos todavía.</td>
						</tr>
					`;
					return;
				}

				brandPathsBody.innerHTML = topPaths
					.map(
						([path, total]) => `
							<tr class="border-t border-zinc-100 dark:border-zinc-700">
								<td class="px-4 py-3 font-mono text-xs md:text-sm">${escapeHtml(path)}</td>
								<td class="px-4 py-3 font-semibold">${total}</td>
							</tr>
						`,
					)
					.join("");
			}

			async function loadMessages(filter = "todos") {
				let query = supabase
					.from("messages")
					.select("*")
					.order("created_at", { ascending: false });

				if (filter !== "todos") {
					query = query.eq("status", filter);
				}

				const { data, error } = await query;

				if (error) {
					messagesBody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-red-500">Error: ${error.message}</td></tr>`;
					return;
				}

				const messages = data || [];
				msgCount.textContent = String(messages.length);

				// Actualizar stats (siempre total)
				const { data: allMsgs } = await supabase
					.from("messages")
					.select("status");
				const all = allMsgs || [];
				statTotal.textContent = String(all.length);
				statNuevo.textContent = String(
					all.filter((m) => m.status === "nuevo").length,
				);
				statLeido.textContent = String(
					all.filter((m) => m.status === "leído").length,
				);
				statRespondido.textContent = String(
					all.filter((m) => m.status === "respondido").length,
				);

				if (messages.length === 0) {
					messagesBody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-gray-500 dark:text-gray-300">No hay mensajes</td></tr>`;
					return;
				}

				messagesBody.innerHTML = messages
					.map(
						(msg) => `
					<tr class="border-b border-zinc-100 dark:border-zinc-700 hover:bg-zinc-50 dark:hover:bg-zinc-700/30 cursor-pointer transition" data-id="${msg.id}">
						<td class="px-4 py-3">${statusEmoji[msg.status] || "⚪"} <span class="text-xs">${msg.status}</span></td>
						<td class="px-4 py-3 font-medium">${escapeHtml(msg.name)}</td>
						<td class="px-4 py-3 hidden md:table-cell text-gray-500 dark:text-gray-300">${escapeHtml(msg.email)}</td>
						<td class="px-4 py-3 hidden lg:table-cell text-gray-500 dark:text-gray-300 truncate max-w-xs">${escapeHtml(msg.message.substring(0, 60))}${msg.message.length > 60 ? "…" : ""}</td>
						<td class="px-4 py-3 text-xs text-gray-400 dark:text-gray-300">${formatDate(msg.created_at)}</td>
						<td class="px-4 py-3">
							<button class="view-msg-btn text-xs text-orange-500 hover:underline" data-id="${msg.id}">Ver</button>
						</td>
					</tr>
				`,
					)
					.join("");

				// Añadir eventos a botones "Ver"
				document.querySelectorAll(".view-msg-btn").forEach((btn) => {
					btn.addEventListener("click", (e) => {
						e.stopPropagation();
						const id = (btn as HTMLElement).dataset.id!;
						const msg = messages.find((m) => m.id === id);
						if (msg) openModal(msg);
					});
				});

				// Clic en fila
				messagesBody.querySelectorAll("tr[data-id]").forEach((row) => {
					row.addEventListener("click", () => {
						const id = (row as HTMLElement).dataset.id!;
						const msg = messages.find((m) => m.id === id);
						if (msg) openModal(msg);
					});
				});
			}

			// === Modal ===
			function openModal(msg: {
				id: string;
				name: string;
				email: string;
				message: string;
				created_at: string;
				status: string;
			}) {
				currentMsgId = msg.id;
				modalName.textContent = msg.name;
				modalEmail.textContent = msg.email;
				modalDate.textContent = new Date(msg.created_at).toLocaleString(
					"es-ES",
				);
				modalMessage.textContent = msg.message;
				modal.classList.remove("hidden");
			}

			modalClose.addEventListener("click", () => {
				modal.classList.add("hidden");
				currentMsgId = null;
			});

			modal.addEventListener("click", (e) => {
				if (e.target === modal) {
					modal.classList.add("hidden");
					currentMsgId = null;
				}
			});

			// Botones de cambio de estado en modal
			document.querySelectorAll(".modal-status-btn").forEach((btn) => {
				btn.addEventListener("click", async () => {
					if (!currentMsgId) return;
					const newStatus = (btn as HTMLElement).dataset.action!;
					await supabase
						.from("messages")
						.update({ status: newStatus })
						.eq("id", currentMsgId);
					modal.classList.add("hidden");
					currentMsgId = null;
					loadMessages(filterStatus.value);
				});
			});

			// === Filtro ===
			filterStatus.addEventListener("change", () => {
				loadMessages(filterStatus.value);
			});

			brandMetricsRefresh?.addEventListener("click", () => {
				renderBrandMetrics();
			});

			// === Utilidades ===
			function escapeHtml(text: string): string {
				const div = document.createElement("div");
				div.textContent = text;
				return div.innerHTML;
			}

			function formatDate(iso: string): string {
				const d = new Date(iso);
				return (
					d.toLocaleDateString("es-ES", { day: "2-digit", month: "short" }) +
					" " +
					d.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" })
				);
			}

			// === Init ===
			checkSession();
		</script>
	</body>
</html>
