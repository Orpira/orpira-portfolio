---
import ProjectLayout from "../../layouts/ProjectLayout.astro";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<ProjectLayout
	title="Private Balance | Finance App PWA y Android"
	description="Private Balance es una aplicación financiera privada, mobile-first y disponible como PWA, con versión Android mediante Capacitor."
>
	<section class="finance-page space-y-12">
		<header class="relative overflow-hidden rounded-[2rem] border border-emerald-300/15 bg-gradient-to-br from-emerald-400/[0.12] via-cyan-400/[0.06] to-violet-400/[0.1] px-5 py-10 text-center shadow-2xl shadow-black/20 md:px-10 md:py-16">
			<div aria-hidden="true" class="absolute -left-24 -top-24 size-64 rounded-full bg-emerald-400/15 blur-3xl"></div>
			<div aria-hidden="true" class="absolute -bottom-28 -right-20 size-72 rounded-full bg-violet-400/15 blur-3xl"></div>
			<a
				href="/#projects"
				class="project-cta relative inline-flex items-center rounded-full border border-white/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-accent hover:border-brand-accent hover:bg-brand-accent/10"
			>
				Volver a proyectos
			</a>

			<div class="relative mt-7 space-y-5">
				<span class="inline-flex rounded-full border border-cyan-300/25 bg-cyan-300/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-cyan-100">
					PWA / Web / Android Preview
				</span>
				<h1
					class="font-display text-5xl font-semibold leading-none text-orange-100 md:text-7xl"
				>
					Private Balance
				</h1>
				<p class="mx-auto max-w-3xl text-base leading-relaxed text-brand-muted md:text-lg">
					Private Balance es una aplicación financiera privada orientada a móvil
					que permite registrar ingresos, egresos y ganancias, ocultar importes
					sensibles y consultar un resumen mensual desde una experiencia visual
					tipo app bancaria.
				</p>
				<div class="flex flex-col items-center justify-center gap-3 pt-2 sm:flex-row">
					<a href="https://private-balance.orpira.es/" target="_blank" rel="noopener noreferrer" class="project-cta inline-flex w-full items-center justify-center rounded-full border border-emerald-300/50 bg-emerald-300/15 px-6 py-3 text-sm font-semibold text-emerald-100 hover:bg-emerald-300/25 sm:w-auto">
						Abrir demo PWA <span aria-hidden="true" class="ml-2">↗</span>
					</a>
					<a href="#android-preview" class="project-cta inline-flex w-full items-center justify-center rounded-full border border-cyan-300/40 px-6 py-3 text-sm font-semibold text-cyan-100 hover:bg-cyan-300/10 sm:w-auto">
						Ver Android Preview <span aria-hidden="true" class="ml-2">↓</span>
					</a>
				</div>
			</div>
		</header>

		<section class="grid gap-7 rounded-3xl border border-white/12 bg-white/[0.04] p-5 shadow-xl md:grid-cols-[1.15fr_0.85fr] md:p-8">
			<div class="space-y-4">
				<p class="editorial-kicker micro-label text-emerald-100">Demo PWA / Web</p>
				<h2 class="font-display text-3xl font-semibold text-orange-100 md:text-4xl">Tu gestión financiera, disponible desde cualquier navegador.</h2>
				<p class="leading-relaxed text-brand-muted">La versión desplegada de Private Balance puede abrirse desde móvil o escritorio. En navegadores compatibles también puede instalarse como PWA para acceder con una experiencia similar a una aplicación nativa.</p>
				<a href="https://private-balance.orpira.es/" target="_blank" rel="noopener noreferrer" class="project-cta inline-flex items-center rounded-full border border-emerald-300/45 px-5 py-3 text-sm font-semibold text-emerald-100 hover:bg-emerald-300/10">private-balance.orpira.es <span aria-hidden="true" class="ml-2">↗</span></a>
			</div>
			<div class="grid gap-3 sm:grid-cols-3 md:grid-cols-1">
				<div class="rounded-2xl border border-emerald-300/15 bg-emerald-300/[0.07] p-4"><p class="font-semibold text-emerald-100">Responsive</p><p class="mt-1 text-sm text-brand-muted">Móvil y escritorio</p></div>
				<div class="rounded-2xl border border-cyan-300/15 bg-cyan-300/[0.07] p-4"><p class="font-semibold text-cyan-100">Instalable</p><p class="mt-1 text-sm text-brand-muted">Experiencia PWA</p></div>
				<div class="rounded-2xl border border-violet-300/15 bg-violet-300/[0.07] p-4"><p class="font-semibold text-violet-100">Privada</p><p class="mt-1 text-sm text-brand-muted">Datos bajo control</p></div>
			</div>
		</section>

		<section
			id="finance-demo"
			class="rounded-3xl border border-white/12 bg-white/[0.04] p-4 shadow-2xl shadow-black/20 backdrop-blur md:p-6"
		>
			<div class="mb-6 flex flex-col justify-between gap-4 md:flex-row md:items-end">
				<div>
					<p class="editorial-kicker micro-label">Panel demo</p>
					<h2 class="mt-2 font-display text-2xl font-semibold text-orange-100">
						Movimientos personales
					</h2>
				</div>
				<a
					href="#android-preview"
					class="project-cta inline-flex w-fit items-center rounded-full border border-cyan-300/45 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-cyan-100 hover:bg-cyan-300/10"
				>
					Vista Android
				</a>
			</div>

			<div class="grid gap-4 md:grid-cols-3">
				<div class="rounded-2xl border border-emerald-300/20 bg-emerald-300/10 p-4">
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-emerald-100">
						Ingresos
					</p>
					<p
						id="total-income"
						class="mt-3 font-display text-3xl font-semibold text-white"
					>
						0,00 €
					</p>
				</div>
				<div class="rounded-2xl border border-rose-300/20 bg-rose-300/10 p-4">
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-rose-100">
						Gastos
					</p>
					<p
						id="total-expense"
						class="mt-3 font-display text-3xl font-semibold text-white"
					>
						0,00 €
					</p>
				</div>
				<div class="rounded-2xl border border-orange-300/25 bg-orange-300/10 p-4">
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-orange-100">
						Balance
					</p>
					<p id="total-balance" class="mt-3 font-display text-3xl font-semibold text-white">
						0,00 €
					</p>
				</div>
			</div>

			<div class="mt-8 grid gap-6 lg:grid-cols-[0.9fr_1.4fr]">
				<form
					id="finance-form"
					class="space-y-4 rounded-2xl border border-white/12 bg-brand-card/80 p-4"
				>
					<div>
						<label
							for="movement-type"
							class="mb-2 block text-sm font-semibold text-orange-100"
						>
							Tipo
						</label>
						<select
							id="movement-type"
							name="type"
							class="w-full rounded-xl border-white/15 bg-zinc-950/80 text-white focus:border-brand-accent focus:ring-brand-accent"
						>
							<option value="income">Ingreso</option>
							<option value="expense">Gasto</option>
						</select>
					</div>

					<div>
						<label
							for="movement-description"
							class="mb-2 block text-sm font-semibold text-orange-100"
						>
							Descripcion
						</label>
						<input
							id="movement-description"
							name="description"
							type="text"
							maxlength="120"
							placeholder="Ej. Nomina demo"
							class="w-full rounded-xl border-white/15 bg-zinc-950/80 text-white placeholder:text-zinc-500 focus:border-brand-accent focus:ring-brand-accent"
							required
						/>
					</div>

					<div>
						<label
							for="movement-category"
							class="mb-2 block text-sm font-semibold text-orange-100"
						>
							Categoria
						</label>
						<input
							id="movement-category"
							name="category"
							type="text"
							maxlength="80"
							placeholder="Ej. Demo"
							class="w-full rounded-xl border-white/15 bg-zinc-950/80 text-white placeholder:text-zinc-500 focus:border-brand-accent focus:ring-brand-accent"
						/>
					</div>

					<div>
						<label
							for="movement-amount"
							class="mb-2 block text-sm font-semibold text-orange-100"
						>
							Importe
						</label>
						<input
							id="movement-amount"
							name="amount"
							type="number"
							min="0.01"
							step="0.01"
							placeholder="125.00"
							class="w-full rounded-xl border-white/15 bg-zinc-950/80 text-white placeholder:text-zinc-500 focus:border-brand-accent focus:ring-brand-accent"
							required
						/>
					</div>

					<button
						id="submit-finance-movement"
						type="submit"
						class="project-cta w-full rounded-xl border border-brand-accent/60 bg-brand-accent/15 px-4 py-3 text-sm font-semibold uppercase tracking-[0.14em] text-orange-100 hover:bg-brand-accent/25"
					>
						Guardar movimiento
					</button>

					<p id="finance-message" class="min-h-6 text-sm text-brand-muted"></p>
				</form>

				<div class="overflow-hidden rounded-2xl border border-white/12 bg-zinc-950/55">
					<div
						class="flex flex-col gap-3 border-b border-white/10 px-4 py-3 sm:flex-row sm:items-center sm:justify-between"
					>
						<h3 class="font-semibold text-orange-100">Ultimos movimientos</h3>
						<div class="flex flex-wrap gap-2">
							<button
								id="refresh-finance-movements"
								type="button"
								class="rounded-full border border-white/15 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-brand-muted hover:border-brand-accent hover:text-orange-100"
							>
								Actualizar
							</button>
							<button
								id="clear-finance-movements"
								type="button"
								class="rounded-full border border-rose-300/25 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-rose-100 hover:bg-rose-300/10"
							>
								Borrar demo
							</button>
						</div>
					</div>
					<div class="overflow-x-auto">
						<table class="min-w-full divide-y divide-white/10 text-left text-sm">
							<thead class="bg-white/[0.03] text-xs uppercase tracking-[0.12em] text-brand-muted">
								<tr>
									<th class="px-4 py-3 font-semibold">Fecha</th>
									<th class="px-4 py-3 font-semibold">Tipo</th>
									<th class="px-4 py-3 font-semibold">Descripcion</th>
									<th class="px-4 py-3 font-semibold">Categoria</th>
									<th class="px-4 py-3 text-right font-semibold">Importe</th>
									<th class="px-4 py-3 text-right font-semibold">Acciones</th>
								</tr>
							</thead>
							<tbody id="finance-table-body" class="divide-y divide-white/10 text-zinc-100">
								<tr>
									<td colspan="6" class="px-4 py-6 text-center text-brand-muted">
										Cargando movimientos demo...
									</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

		<section
			id="android-preview"
			class="scroll-mt-8 overflow-hidden rounded-3xl border border-white/12 bg-gradient-to-br from-white/[0.05] via-cyan-300/[0.05] to-violet-300/[0.08] p-5 shadow-2xl shadow-cyan-950/20 md:p-10"
		>
			<div class="grid items-center gap-10 md:grid-cols-[0.85fr_1.15fr]">
				<div class="space-y-5">
					<p class="editorial-kicker micro-label text-cyan-100">Android Preview</p>
					<h2 class="font-display text-3xl font-semibold text-orange-100 md:text-4xl">Una experiencia financiera diseñada para sentirse nativa.</h2>
					<p class="leading-relaxed text-brand-muted">Vista Android de Private Balance, diseñada con enfoque mobile-first, navegación inferior tipo app nativa, tarjetas financieras y opción de ocultar valores sensibles.</p>
					<p class="leading-relaxed text-brand-muted">La versión Android se genera mediante Capacitor a partir de la base PWA/Web, manteniendo una única experiencia de producto y acceso a capacidades nativas.</p>
				</div>
				<figure class="mx-auto w-full max-w-[24rem]">
					<div class="rounded-[2.8rem] border border-white/15 bg-zinc-950 p-3 shadow-2xl shadow-black/50 ring-1 ring-cyan-300/10">
						<div class="overflow-hidden rounded-[2.15rem] bg-black">
							<img src="/projects/private-balance/android-preview.jpg" alt="Pantalla de inicio de Private Balance en Android con resumen de ingresos, egresos y ganancia" width="1080" height="2340" loading="lazy" class="h-auto w-full object-cover" />
						</div>
					</div>
					<figcaption class="mt-4 text-center text-xs leading-relaxed text-brand-muted">Captura real de Private Balance ejecutándose en Android.</figcaption>
				</figure>
			</div>
		</section>

		<section class="space-y-6">
			<div class="text-center">
				<p class="editorial-kicker micro-label text-emerald-100">Capacidades</p>
				<h2 class="mt-3 font-display text-3xl font-semibold text-orange-100 md:text-4xl">Características principales</h2>
			</div>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{["Registro de ingresos", "Registro de egresos", "Cálculo de ganancia", "Ocultar valores sensibles", "Resumen mensual", "Interfaz mobile-first", "Navegación tipo app bancaria", "Preparada para PWA / Android"].map((feature, index) => (
					<div class="rounded-2xl border border-white/10 bg-white/[0.035] p-5 shadow-lg shadow-black/10">
						<span class="text-xs font-semibold text-emerald-100">0{index + 1}</span>
						<h3 class="mt-3 font-semibold leading-snug text-orange-100">{feature}</h3>
					</div>
				))}
			</div>
		</section>

		<section class="rounded-3xl border border-white/12 bg-gradient-to-r from-emerald-300/[0.07] via-cyan-300/[0.05] to-violet-300/[0.07] p-6 text-center md:p-8">
			<p class="editorial-kicker micro-label text-cyan-100">Stack técnico</p>
			<div class="project-stack mt-5 justify-center">
				{["React", "TypeScript", "Vite", "Tailwind CSS", "IndexedDB", "PWA", "Vercel", "Capacitor Android"].map((tech) => <span>{tech}</span>)}
			</div>
			<a href="https://private-balance.orpira.es/" target="_blank" rel="noopener noreferrer" class="project-cta mt-7 inline-flex items-center rounded-full border border-emerald-300/45 bg-emerald-300/10 px-6 py-3 text-sm font-semibold text-emerald-100 hover:bg-emerald-300/20">Abrir demo PWA <span aria-hidden="true" class="ml-2">↗</span></a>
		</section>
	</section>

	<script is:inline define:vars={{ supabaseUrl, supabaseAnonKey }}>
		const form = document.getElementById("finance-form");
		const message = document.getElementById("finance-message");
		const submitButton = document.getElementById("submit-finance-movement");
		const refreshButton = document.getElementById("refresh-finance-movements");
		const clearButton = document.getElementById("clear-finance-movements");
		const openMobileButton = document.getElementById("open-mobile-demo");
		const tableBody = document.getElementById("finance-table-body");
		const totalIncome = document.getElementById("total-income");
		const totalExpense = document.getElementById("total-expense");
		const totalBalance = document.getElementById("total-balance");
		const mobileIncome = document.getElementById("mobile-income");
		const mobileExpense = document.getElementById("mobile-expense");
		const mobileBalance = document.getElementById("mobile-balance");
		const mobileMovements = document.getElementById("mobile-movements");
		const mobileMovementCount = document.getElementById("mobile-movement-count");
		const mobileRefreshButton = document.getElementById(
			"mobile-refresh-finance-movements",
		);
		const mobileClearButton = document.getElementById(
			"mobile-clear-finance-movements",
		);
		const mobileDemo = document.getElementById("mobile-demo");

		const moneyFormatter = new Intl.NumberFormat("es-ES", {
			style: "currency",
			currency: "EUR",
		});

		const dateFormatter = new Intl.DateTimeFormat("es-ES", {
			day: "2-digit",
			month: "short",
			hour: "2-digit",
			minute: "2-digit",
		});

		const setMessage = (text, tone = "muted") => {
			if (!message) return;
			message.textContent = text;
			message.className =
				tone === "error"
					? "min-h-6 text-sm text-rose-200"
					: tone === "success"
						? "min-h-6 text-sm text-emerald-200"
						: "min-h-6 text-sm text-brand-muted";
		};

		const formatAmount = (value) => moneyFormatter.format(Number(value) || 0);

		const escapeHtml = (value) =>
			String(value ?? "")
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;")
				.replaceAll("'", "&#039;");

		const fetchMovements = async () => {
			if (!supabaseUrl || !supabaseAnonKey) {
				throw new Error("Faltan variables publicas de Supabase.");
			}

			const response = await fetch(
				`${supabaseUrl}/rest/v1/finance_movements?select=id,type,description,amount,category,created_at&order=created_at.desc&limit=50`,
				{
					headers: {
						apikey: supabaseAnonKey,
						Authorization: `Bearer ${supabaseAnonKey}`,
					},
				},
			);

			if (!response.ok) {
				throw new Error("No se pudieron cargar los movimientos demo.");
			}

			return response.json();
		};

		const deleteMovements = async (payload) => {
			const response = await fetch("/api/finance-demo", {
				method: "DELETE",
				headers: {
					"Content-Type": "application/json",
				},
				body: JSON.stringify(payload),
			});
			const result = await response.json();

			if (!response.ok || !result.success) {
				throw new Error(result.error || "No se pudieron borrar los datos demo.");
			}

			return result;
		};

		const setDeletingState = (isDeleting) => {
			const buttons = document.querySelectorAll("[data-delete-movement]");
			buttons.forEach((button) => {
				if (isDeleting) {
					button.setAttribute("disabled", "true");
				} else {
					button.removeAttribute("disabled");
				}
			});
		};

		const clearDemoData = async () => {
			if (!window.confirm("Quieres borrar todos los movimientos demo?")) {
				return;
			}

			const originalClearText = clearButton?.textContent;
			const originalMobileClearText = mobileClearButton?.textContent;

			if (clearButton) {
				clearButton.setAttribute("disabled", "true");
				clearButton.textContent = "Borrando...";
			}
			if (mobileClearButton) {
				mobileClearButton.setAttribute("disabled", "true");
				mobileClearButton.textContent = "Borrando...";
			}

			try {
				setMessage("Borrando datos demo...");
				await deleteMovements({ all: true });
				setMessage("Datos demo borrados correctamente.", "success");
				await loadMovements();
			} catch (error) {
				setMessage(error.message || "Error al borrar los datos demo.", "error");
			} finally {
				if (clearButton) {
					clearButton.removeAttribute("disabled");
					clearButton.textContent = originalClearText || "Borrar demo";
				}
				if (mobileClearButton) {
					mobileClearButton.removeAttribute("disabled");
					mobileClearButton.textContent = originalMobileClearText || "Borrar";
				}
			}
		};

		const renderMovements = (movements) => {
			const income = movements
				.filter((movement) => movement.type === "income")
				.reduce((sum, movement) => sum + Number(movement.amount), 0);
			const expense = movements
				.filter((movement) => movement.type === "expense")
				.reduce((sum, movement) => sum + Number(movement.amount), 0);
			const balance = income - expense;

			if (totalIncome) totalIncome.textContent = formatAmount(income);
			if (totalExpense) totalExpense.textContent = formatAmount(expense);
			if (totalBalance) totalBalance.textContent = formatAmount(balance);
			if (mobileIncome) mobileIncome.textContent = formatAmount(income);
			if (mobileExpense) mobileExpense.textContent = formatAmount(expense);
			if (mobileBalance) mobileBalance.textContent = formatAmount(balance);
			if (mobileMovementCount) {
				mobileMovementCount.textContent =
					movements.length === 1 ? "1 registro" : `${movements.length} registros`;
			}

			if (tableBody) {
				if (movements.length === 0) {
					tableBody.innerHTML = `
						<tr>
							<td colspan="6" class="px-4 py-6 text-center text-brand-muted">
								Aun no hay movimientos demo. Crea el primero desde el formulario.
							</td>
						</tr>
					`;
				} else {
					tableBody.innerHTML = movements
						.map((movement) => {
							const isIncome = movement.type === "income";
							const badgeClass = isIncome
								? "bg-emerald-300/10 text-emerald-100 border-emerald-300/25"
								: "bg-rose-300/10 text-rose-100 border-rose-300/25";

							return `
								<tr>
									<td class="whitespace-nowrap px-4 py-3 text-brand-muted">
										${dateFormatter.format(new Date(movement.created_at))}
									</td>
									<td class="px-4 py-3">
										<span class="rounded-full border px-2.5 py-1 text-xs font-semibold ${badgeClass}">
											${isIncome ? "Ingreso" : "Gasto"}
										</span>
									</td>
									<td class="px-4 py-3 text-white">${escapeHtml(movement.description)}</td>
									<td class="px-4 py-3 text-brand-muted">${escapeHtml(movement.category || "Demo")}</td>
									<td class="whitespace-nowrap px-4 py-3 text-right font-semibold ${isIncome ? "text-emerald-100" : "text-rose-100"}">
										${isIncome ? "+" : "-"}${formatAmount(movement.amount)}
									</td>
									<td class="px-4 py-3 text-right">
										<button
											type="button"
											data-delete-movement="${escapeHtml(movement.id)}"
											class="rounded-full border border-rose-300/25 px-3 py-1.5 text-xs font-semibold text-rose-100 hover:bg-rose-300/10 disabled:cursor-not-allowed disabled:opacity-50"
										>
											Borrar
										</button>
									</td>
								</tr>
							`;
						})
						.join("");
				}
			}

			if (mobileMovements) {
				const latest = movements.slice(0, 4);
				mobileMovements.innerHTML = latest.length
					? latest
							.map((movement) => {
								const isIncome = movement.type === "income";
								return `
									<div class="rounded-2xl border border-white/10 p-3">
										<div class="flex items-start justify-between gap-3">
											<div class="min-w-0">
												<p class="truncate text-sm font-semibold text-white">${escapeHtml(movement.description)}</p>
												<p class="text-xs text-brand-muted">${escapeHtml(movement.category || "Demo")}</p>
											</div>
											<p class="shrink-0 text-sm font-semibold ${isIncome ? "text-emerald-100" : "text-rose-100"}">
												${isIncome ? "+" : "-"}${formatAmount(movement.amount)}
											</p>
										</div>
										<div class="mt-2 flex items-center justify-between gap-3 text-xs text-brand-muted">
											<span>${dateFormatter.format(new Date(movement.created_at))}</span>
											<button
												type="button"
												data-delete-movement="${escapeHtml(movement.id)}"
												class="rounded-full border border-rose-300/25 px-2.5 py-1 text-[0.68rem] font-semibold text-rose-100 hover:bg-rose-300/10 disabled:cursor-not-allowed disabled:opacity-50"
											>
												Borrar
											</button>
										</div>
									</div>
								`;
							})
							.join("")
					: `<div class="rounded-2xl border border-white/10 p-3 text-sm text-brand-muted">Los ultimos movimientos apareceran aqui.</div>`;
			}
		};

		const loadMovements = async () => {
			try {
				setMessage("Cargando movimientos demo...");
				const movements = await fetchMovements();
				renderMovements(movements);
				setMessage("Demo conectada a Supabase.");
			} catch (error) {
				setMessage(error.message || "Error al cargar la demo.", "error");
				if (tableBody) {
					tableBody.innerHTML = `
						<tr>
							<td colspan="6" class="px-4 py-6 text-center text-rose-200">
								No se pudieron cargar los movimientos.
							</td>
						</tr>
					`;
				}
			}
		};

		refreshButton?.addEventListener("click", loadMovements);
		mobileRefreshButton?.addEventListener("click", loadMovements);
		clearButton?.addEventListener("click", clearDemoData);
		mobileClearButton?.addEventListener("click", clearDemoData);
		openMobileButton?.addEventListener("click", () => {
			if (!mobileDemo) return;

			mobileDemo.scrollIntoView({
				behavior: "smooth",
				block: "center",
				inline: "nearest",
			});
			mobileDemo.focus({ preventScroll: true });
			mobileDemo.classList.add("shadow-[0_0_0_4px_rgba(103,232,249,0.35)]");

			window.setTimeout(() => {
				mobileDemo.classList.remove(
					"shadow-[0_0_0_4px_rgba(103,232,249,0.35)]",
				);
			}, 1300);
		});

		document.addEventListener("click", async (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			const deleteButton = target.closest("[data-delete-movement]");
			if (!(deleteButton instanceof HTMLElement)) return;

			const id = deleteButton.dataset.deleteMovement;
			if (!id) return;

			try {
				setDeletingState(true);
				deleteButton.textContent = "Borrando...";
				setMessage("Borrando movimiento demo...");
				await deleteMovements({ id });
				setMessage("Movimiento demo borrado.", "success");
				await loadMovements();
			} catch (error) {
				setMessage(error.message || "Error al borrar el movimiento.", "error");
			} finally {
				setDeletingState(false);
			}
		});

		form?.addEventListener("submit", async (event) => {
			event.preventDefault();

			const formData = new FormData(form);
			const type = formData.get("type");
			const description = String(formData.get("description") || "").trim();
			const category = String(formData.get("category") || "").trim();
			const amount = Number(formData.get("amount"));

			if (type !== "income" && type !== "expense") {
				setMessage("Selecciona un tipo valido.", "error");
				return;
			}

			if (!description) {
				setMessage("La descripcion es obligatoria.", "error");
				return;
			}

			if (!Number.isFinite(amount) || amount <= 0) {
				setMessage("El importe debe ser mayor que 0.", "error");
				return;
			}

			if (submitButton) {
				submitButton.setAttribute("disabled", "true");
				submitButton.textContent = "Guardando...";
			}

			try {
				const response = await fetch("/api/finance-demo", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({
						type,
						description,
						category,
						amount,
					}),
				});
				const result = await response.json();

				if (!response.ok || !result.success) {
					throw new Error(result.error || "No se pudo guardar el movimiento.");
				}

				form.reset();
				setMessage("Movimiento demo guardado correctamente.", "success");
				await loadMovements();
			} catch (error) {
				setMessage(error.message || "Error al guardar el movimiento.", "error");
			} finally {
				if (submitButton) {
					submitButton.removeAttribute("disabled");
					submitButton.textContent = "Guardar movimiento";
				}
			}
		});

		loadMovements();
	</script>

