---
import { brandProjects } from "../data/projects";

interface Props {
	baseUrl: string;
}
const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";

const resolveProjectHref = (href?: string, isExternal?: boolean) => {
	if (!href) return undefined;
	if (isExternal) return href;
	if (!href.startsWith("/")) return href;
	return `${siteBase}${href}`;
};
---

<section id="projects" class="py-20 section-divider">
	<div class="text-center mb-12 md:mb-14">
		<p class="editorial-kicker micro-label" data-reveal style="--delay: 40ms;">
			Project ecosystem
		</p>
		<h2
			class="section-title-contrast project-section-title font-display font-semibold text-4xl md:text-5xl mt-3"
			data-reveal
			style="--delay: 120ms;"
		>
			Un grid vivo para lanzar, medir y escalar proyectos.
		</h2>
		<p
			class="mt-4 max-w-3xl mx-auto text-zinc-700 dark:text-brand.muted"
			data-reveal
			style="--delay: 200ms;"
		>
			Cada tarjeta representa una pieza del ecosistema Orpira en Vercel. La
			estructura es modular: puedes sumar nuevos proyectos sin romper la
			narrativa de marca.
		</p>
	</div>

	<div class="project-mosaic">
		{
			brandProjects.map((project, index) => (
				<article
					class={`project-tile project-${project.layout} flex flex-col justify-between gap-6`}
					style={`--tile-accent: ${project.accent}; --delay: ${280 + index * 90}ms;`}
					data-reveal
				>
					<div class="space-y-4">
						<div class="flex items-start justify-between gap-3">
							<p class="editorial-kicker micro-label !text-[0.62rem] !tracking-[0.2em] text-zinc-600 dark:text-zinc-200 font-semibold">
								{project.domain}
							</p>
							<span
								class={`micro-accent rounded-full px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.14em] ${project.comingSoon ? "bg-zinc-800/80 text-zinc-100 border border-zinc-500/85" : "bg-brand.accent/25 text-orange-950 dark:text-amber-100 border border-brand.accent/60"}`}
							>
								{project.status}
							</span>
						</div>

						<h3 class="project-card-title font-display text-2xl md:text-3xl leading-tight">
							{project.title}
						</h3>

						<p class="text-sm md:text-base leading-relaxed text-zinc-700 dark:text-brand.muted">
							{project.summary}
						</p>

						<div class="project-stack">
							{project.stack.map((tech) => (
								<span>{tech}</span>
							))}
						</div>
					</div>

					<div class="flex items-center justify-between gap-4 border-t border-white/10 dark:border-white/10 pt-4">
						<span class="micro-label text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600 dark:text-zinc-200">
							{project.year}
						</span>

						{project.comingSoon ? (
							<span class="micro-label text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-200">
								En configuracion
							</span>
						) : (
							<a
								href={resolveProjectHref(project.href, project.external)}
								target={project.external ? "_blank" : undefined}
								rel={project.external ? "noopener noreferrer" : undefined}
								class="project-cta inline-flex items-center gap-2 rounded-full border border-brand.accent/45 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand.accent hover:border-brand.accent hover:bg-brand.accent/10"
							>
								{project.cta}
							</a>
						)}
					</div>
				</article>
			))
		}
	</div>
</section>
