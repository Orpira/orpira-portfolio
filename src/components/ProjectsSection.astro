---
interface Props {
	baseUrl: string;
}
const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";
---

<section id="projects" class="py-20 section-divider">
	<h2
		class="text-3xl md:text-4xl font-serif font-bold text-center mb-12 text-brand.accent"
	>
		Proyectos Destacados
	</h2>

	<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
		<article
			class="bg-brand.card p-6 rounded-xl border border-zinc-700 hover:border-brand.accent transition"
		>
			<a href={`${siteBase}/projects/control-horario`} class="block">
				<h3 class="text-xl font-semibold mb-1">Control Horario Laboral</h3>
				<p class="text-sm text-gray-600 dark:text-brand.muted mb-4">
					Sistema web para fichaje y cálculo de horas.
				</p>
				<p class="text-sm">
					✔ Backend en Laravel ✔ Base de datos SQLite ✔ Panel de control para
					RRHH
				</p>
			</a>
		</article>

		<article
			class="bg-brand.card p-6 rounded-xl border border-zinc-700 hover:border-brand.accent transition"
		>
			<h3 class="text-xl font-semibold mb-1">Plataforma Educativa</h3>
			<p class="text-sm text-gray-600 dark:text-brand.muted mb-4">
				Quizzes interactivos con autenticación y progreso.
			</p>
			<p class="text-sm">
				✔ React + Vite ✔ Firebase ✔ UI/UX para aprendizaje interactivo
			</p>
		</article>

		<article
			class="bg-brand.card p-6 rounded-xl border border-zinc-700 hover:border-brand.accent transition"
		>
			<h3 class="text-xl font-semibold mb-1">Portafolio Profesional</h3>
			<p class="text-sm text-gray-600 dark:text-brand.muted mb-4">
				Sitio personal con modo oscuro y branding propio.
			</p>
			<p class="text-sm">
				✔ Astro + Tailwind ✔ Diseño visual ✔ Optimización SEO
			</p>
		</article>
	</div>
</section>
