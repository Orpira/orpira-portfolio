---
interface Props {
	title: string;
	description: string;
	year: string;
	tech: string[];
	role: string;
	features: string[];
	result?: string;
	image?: string;
}

const { title, description, year, tech, role, features, result, image } =
	Astro.props;
---

<article class="space-y-10">
	<!-- Header -->
	<header class="text-center">
		<h1
			class="text-3xl md:text-4xl font-serif font-bold text-orange-800 dark:text-orange-100 mb-4"
		>
			{title}
		</h1>

		<p class="text-brand.muted max-w-2xl mx-auto text-zinc-700 dark:text-zinc-100">
			{description}
		</p>
	</header>

	<!-- Imagen principal opcional -->
	{
		image && (
			<div class="flex justify-center">
				<img
					src={image}
					class="rounded-xl shadow-lg max-h-80 object-cover"
					alt={title}
				/>
			</div>
		)
	}

	<!-- Info general -->
	<section
		class="grid md:grid-cols-3 gap-8 bg-gradient-to-br from-orange-100/80 to-white shadow-xl border-2 border-orange-300 dark:bg-gradient-to-br dark:from-zinc-900 dark:via-orange-900/40 dark:to-zinc-800 dark:border-orange-500 rounded-3xl p-4 md:p-10"
	>
		<div>
			<h3 class="font-semibold text-orange-800 dark:text-orange-100">Año</h3>
			<p class="text-orange-900 dark:text-orange-100">{year}</p>
		</div>

		<div>
			<h3 class="font-semibold text-orange-800 dark:text-orange-100">Rol</h3>
			<p class="text-orange-900 dark:text-orange-100">{role}</p>
		</div>

		<div>
			<h3 class="font-semibold text-orange-800 dark:text-orange-100">Tecnologías</h3>
			<ul class="text-sm mt-1 space-y-1 text-orange-900 dark:text-orange-100">
				{tech.map((t: string) => <li>• {t}</li>)}
			</ul>
		</div>
	</section>

	<!-- Funcionalidades -->
	<section>
		<h3 class="text-xl font-semibold mb-4 text-orange-800 dark:text-orange-100">Funciones principales</h3>
		<ul class="list-disc ml-6 space-y-1 text-orange-900 dark:text-orange-100">
			{features.map((f: string) => <li>{f}</li>)}
		</ul>
	</section>

	<!-- Resultados -->
	{
		result && (
			<section>
				<h3 class="text-xl font-semibold mb-4 text-orange-800 dark:text-orange-100">Resultados / Impacto</h3>
				<p class="text-zinc-700 dark:text-zinc-100 leading-relaxed">{result}</p>
			</section>
		)
	}

	<!-- Volver -->
	<div class="text-center mt-10">
		<a
			href="/#projects"
			class="px-6 py-3 border border-brand-accent rounded-lg text-orange-800 dark:text-orange-100 hover:bg-brand-accent hover:text-brand-bg transition"
		>
			← Volver a proyectos
		</a>
	</div>
</article>
