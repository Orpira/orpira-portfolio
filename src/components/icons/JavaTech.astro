---
// src/components/icons/JavaTech.astro
interface Props {
	class?: string;
}

const { class: className = "size-4" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const javaIconSrc = `${baseUrl}java-icon.svg`;
---

<img
	src={javaIconSrc}
	alt="Java"
	class={`inline-block ${className}`}
	{...Astro.props}
/>
