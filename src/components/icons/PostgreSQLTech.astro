---
// src/components/icons/PostgreSQLTech.astro
interface Props {
	class?: string;
}

const { class: className = "size-4" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const postgreSqlIconSrc = `${baseUrl}postgresql-icon.svg`;
---

<img
	src={postgreSqlIconSrc}
	alt="PostgreSQL"
	class={`inline-block ${className}`}
	{...Astro.props}
/>
