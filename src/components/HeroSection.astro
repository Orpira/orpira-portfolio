---
interface Props {
	baseUrl: string;
}
const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";

const impactCards = [
	{ value: "15+", label: "años liderando equipos IT" },
	{ value: "30+", label: "proyectos y mejoras ejecutadas" },
	{ value: "24h", label: "respuesta media a oportunidades" },
	{ value: "100%", label: "foco en producto útil" },
];
---

<section id="top" class="relative pt-20 pb-14 md:pt-20 md:pb-20">
	<div
		class="grid items-center lg:items-start gap-12 lg:grid-cols-[1.25fr_0.9fr]"
	>
		<div class="space-y-7">
			<p class="editorial-kicker micro-label" data-reveal style="--delay: 0ms;">
				Orpira Portfolio
			</p>

			<h1
				class="hero-title font-display text-4xl sm:text-5xl lg:text-7xl leading-[0.95] tracking-tight"
				data-reveal
				style="--delay: 90ms;"
			>
				Construyo plataformas digitales que combinan precisión técnica y
				presencia humana.
			</h1>

			<p
				 class="service-card-copy mt-3 text-sm leading-relaxed md:text-lg"
				data-reveal
				style="--delay: 170ms;"
			>
				Soy Orlando Pineda Raad. Ingeniero informático con experiencia real en
				desarrollo, operaciones IT y liderazgo técnico. Este portfolio no es un
				CV — es prueba de ejecución: proyectos vivos, desplegados, en constante
				evolución.
			</p>

			<div class="flex flex-wrap gap-3" data-reveal style="--delay: 250ms;">
				<a
					href="#projects"
					class="hero-cta hero-cta-primary rounded-full px-6 py-3 text-sm font-semibold uppercase tracking-[0.1em]"
				>
					Explorar proyectos
				</a>
				<!-- <a
					href={`${siteBase}/CV_OrlandoPinedaRaad.pdf`}
					class="hero-cta hero-cta-secondary rounded-full border px-6 py-3 text-sm font-semibold uppercase tracking-[0.1em]"
				>
					Descargar CV
				</a> -->
			</div>
		</div>

		<div
			class="hero-visual lg:mt-8 space-y-5"
			data-reveal
			style="--delay: 220ms;"
		>
			<div class="hero-portrait-wrap relative">
				<div class="portrait-shell">
					<img
						src={`${siteBase}/foto_new.JPEG`}
						alt="Foto de Orlando"
						class="portrait-image"
					/>
				</div>
				<div class="hero-quote">De la idea al deploy.</div>
				<div class="hero-orbit" aria-hidden="true"></div>
			</div>

			<dl class="hero-impact-grid grid grid-cols-2 gap-3 pt-1">
				{
					impactCards.map((item) => (
						<div class="hero-impact-card p-4 rounded-2xl bg-white dark:bg-zinc-900 shadow border">
							<dt class="hero-impact-value font-display text-2xl md:text-3xl text-orange-800 dark:text-orange-100">
								{item.value}
							</dt>
							<dd class="hero-impact-label micro-label text-[0.72rem] uppercase tracking-[0.12em] mt-1 text-orange-700 dark:text-orange-200">
								{item.label}
							</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>

<style>
	.hero-cta {
		transition:
			background-color 0.22s ease,
			color 0.22s ease,
			border-color 0.22s ease,
			transform 0.22s ease,
			box-shadow 0.22s ease;
	}

	.hero-cta:hover {
		transform: translateY(-1px);
	}

	.hero-cta-primary {
		background: #ff9b53;
		color: #18130f;
		box-shadow: 0 10px 24px rgba(255, 155, 83, 0.25);
	}

	.hero-cta-primary:hover {
		background: #ffab6f;
	}

	.hero-cta-secondary {
		color: #1f2937;
		border-color: rgba(31, 41, 55, 0.28);
		background: rgba(255, 255, 255, 0.68);
	}

	.hero-cta-secondary:hover {
		color: #111827;
		border-color: rgba(255, 155, 83, 0.7);
	}

	.hero-impact-value {
		color: #ff9b53;
		font-weight: 700;
	}

	.hero-impact-label {
		color: #4b5563;
		font-weight: 600;
	}

	:global(.dark) .hero-cta-primary {
		background: linear-gradient(145deg, #ffb27b, #ff9b53);
		color: #19120e;
		border: 1px solid rgba(255, 184, 133, 0.6);
		box-shadow:
			0 10px 28px rgba(255, 155, 83, 0.34),
			0 0 0 1px rgba(255, 255, 255, 0.08) inset;
	}

	:global(.dark) .hero-cta-secondary {
		color: #f8f6f1;
		border-color: rgba(255, 255, 255, 0.4);
		background: rgba(248, 246, 241, 0.06);
		box-shadow: 0 10px 24px rgba(6, 8, 14, 0.35);
	}

	:global(.dark) .hero-cta-secondary:hover {
		border-color: rgba(255, 155, 83, 0.78);
		color: #ffd9c2;
	}

	:global(.dark) .hero-impact-card {
		background: linear-gradient(
			135deg,
			rgba(255, 255, 255, 0.08),
			rgba(255, 255, 255, 0.035)
		);
		border-color: rgba(255, 255, 255, 0.2);
	}

	:global(.dark) .hero-impact-value {
		color: #ffd9c2;
		text-shadow: 0 6px 16px rgba(255, 155, 83, 0.18);
	}

	:global(.dark) .hero-impact-label {
		color: #d8e0ef;
	}

	.hero-title {
		color: #111827;
		font-weight: 700;
	}

	:global(.dark) .hero-title {
		color: #f8f6f1;
		text-shadow:
			0 1px 0 rgba(0, 0, 0, 0.45),
			0 8px 22px rgba(0, 0, 0, 0.28);
	}

	.portrait-shell {
		position: relative;
		max-width: 26rem;
		margin-inline: auto;
		padding: 0.85rem;
		border-radius: 1.8rem;
		background: linear-gradient(
			145deg,
			rgba(255, 155, 83, 0.28),
			rgba(77, 136, 255, 0.08),
			rgba(255, 155, 83, 0.2)
		);
		box-shadow:
			0 22px 38px rgba(6, 8, 14, 0.45),
			inset 0 0 0 1px rgba(255, 255, 255, 0.16);
	}

	.portrait-image {
		border-radius: 1.35rem;
		width: 100%;
		height: clamp(21rem, 44vw, 31rem);
		object-fit: cover;
		object-position: 50% 16%;
		filter: saturate(0.94) contrast(1.02);
	}

	.hero-quote {
		position: absolute;
		left: -1rem;
		bottom: 1.2rem;
		padding: 0.75rem 1rem;
		border-radius: 9999px;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.66rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: #111827;
		background: rgba(255, 237, 221, 0.94);
		box-shadow: 0 8px 22px rgba(0, 0, 0, 0.22);
	}

	:global(.dark) .hero-quote {
		color: #fef2e8;
		background: rgba(19, 23, 35, 0.88);
		border: 1px solid rgba(255, 255, 255, 0.15);
	}

	.hero-orbit {
		position: absolute;
		right: -1.6rem;
		top: -1.4rem;
		width: 6rem;
		height: 6rem;
		border-radius: 9999px;
		border: 1px solid rgba(255, 255, 255, 0.24);
		box-shadow: inset 0 0 0 1px rgba(255, 155, 83, 0.35);
		animation: orbitSpin 11s linear infinite;
	}

	.hero-orbit::after {
		content: "";
		position: absolute;
		inset: 0.9rem;
		border-radius: 9999px;
		border: 1px dashed rgba(255, 155, 83, 0.6);
	}

	@keyframes orbitSpin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	@media (max-width: 1023px) {
		.hero-quote {
			left: 50%;
			transform: translateX(-50%);
			bottom: -1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-orbit {
			animation: none;
			display: none;
		}
	}
</style>
