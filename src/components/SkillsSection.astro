---
interface Props {
	baseUrl: string;
}
const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";
---

<section id="skills" class="py-20 section-divider">
	<h2
		class="text-3xl md:text-4xl font-serif font-bold text-center mb-12 text-brand.accent"
	>
		Tecnologías y Herramientas
	</h2>

	<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
		<!-- Bases de datos -->
		<div class="relative w-full h-56 perspective group">
			<!-- Indicador para tocar en mobile -->
			<div
				class="flex sm:hidden items-center gap-1 absolute top-3 right-3 px-2 py-0.5 bg-zinc-900/75 text-white text-xs rounded"
			>
				<svg
					class="w-5 h-5 tap-pulse"
					viewBox="0 0 24 24"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<path
						d="M17.65 6.35A7.95 7.95 0 0 0 12 4V1L8 5l4 4V6c2.76 0 5 2.24 5 5a5 5 0 0 1-5 5 5 5 0 0 1-4.9-4H5.1A7 7 0 0 0 12 18c3.87 0 7-3.13 7-7 0-1.86-.67-3.56-1.85-4.9z"
					></path>
				</svg>
				<span class="sr-only">Toca para girar</span>
			</div>
			<div
				class="relative w-full h-full transition-transform duration-500 transform-style-preserve-3d group-hover:[transform:rotateY(180deg)]"
			>
				<div
					class="absolute w-full h-full backface-hidden bg-brand.card rounded-xl border border-zinc-700 flex items-center justify-center"
				>
					<h3 class="text-lg font-semibold">Bases de Datos</h3>
				</div>
				<div
					class="absolute w-full h-full [transform:rotateY(180deg)] backface-hidden bg-brand.card rounded-xl border border-brand.accent p-6 flex items-center justify-center"
				>
					<div class="grid grid-cols-2 gap-4 w-full">
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/postgresql-icon.svg`}
								alt="PostgreSQL"
								class="w-10 h-10 mb-2"
							/>
							<span class="text-sm">PostgreSQL</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/mysql-icon.svg`}
								alt="MySQL"
								class="w-10 h-10 mb-2"
							/>
							<span class="text-sm">MySQL</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Desarrollo -->
		<div class="relative w-full h-56 perspective group">
			<!-- Indicador para tocar en mobile -->
			<div
				class="flex sm:hidden items-center gap-1 absolute top-3 right-3 px-2 py-0.5 bg-zinc-900/75 text-white text-xs rounded"
			>
				<svg
					class="w-5 h-5 tap-pulse"
					viewBox="0 0 24 24"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<path
						d="M17.65 6.35A7.95 7.95 0 0 0 12 4V1L8 5l4 4V6c2.76 0 5 2.24 5 5a5 5 0 0 1-5 5 5 5 0 0 1-4.9-4H5.1A7 7 0 0 0 12 18c3.87 0 7-3.13 7-7 0-1.86-.67-3.56-1.85-4.9z"
					></path>
				</svg>
				<span class="sr-only">Toca para girar</span>
			</div>
			<div
				class="relative w-full h-full transition-transform duration-500 transform-style-preserve-3d group-hover:[transform:rotateY(180deg)]"
			>
				<div
					class="absolute w-full h-full backface-hidden bg-brand.card rounded-xl border border-zinc-700 flex items-center justify-center"
				>
					<h3 class="text-lg font-semibold">Lenguajes</h3>
				</div>
				<div
					class="absolute w-full h-full [transform:rotateY(180deg)] backface-hidden bg-brand.card rounded-xl border border-brand.accent p-6 flex items-center justify-center"
				>
					<div class="grid grid-cols-2 gap-4 w-full">
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/javascript-icon.svg`}
								alt="JavaScript"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">JavaScript</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/typescriptlang-icon.svg`}
								alt="TypeScript"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">TypeScript</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/java-icon.svg`}
								alt="Java"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">Java</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/w3_html5-icon.svg`}
								alt="HTML/CSS"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">HTML/CSS</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Frameworks -->
		<div class="relative w-full h-56 perspective group">
			<!-- Indicador para tocar en mobile -->
			<div
				class="flex sm:hidden items-center gap-1 absolute top-3 right-3 px-2 py-0.5 bg-zinc-900/75 text-white text-xs rounded"
			>
				<svg
					class="w-5 h-5 tap-pulse"
					viewBox="0 0 24 24"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<path
						d="M17.65 6.35A7.95 7.95 0 0 0 12 4V1L8 5l4 4V6c2.76 0 5 2.24 5 5a5 5 0 0 1-5 5 5 5 0 0 1-4.9-4H5.1A7 7 0 0 0 12 18c3.87 0 7-3.13 7-7 0-1.86-.67-3.56-1.85-4.9z"
					></path>
				</svg>
				<span class="sr-only">Toca para girar</span>
			</div>
			<div
				class="relative w-full h-full transition-transform duration-500 transform-style-preserve-3d group-hover:[transform:rotateY(180deg)]"
			>
				<div
					class="absolute w-full h-full backface-hidden bg-brand.card rounded-xl border border-zinc-700 flex items-center justify-center"
				>
					<h3 class="text-lg font-semibold">Frameworks</h3>
				</div>
				<div
					class="absolute w-full h-full [transform:rotateY(180deg)] backface-hidden bg-brand.card rounded-xl border border-brand.accent p-6 flex items-center justify-center"
				>
					<div class="grid grid-cols-2 gap-4 w-full">
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/reactjs-icon.svg`}
								alt="React"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">React</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/tailwindcss-icon.svg`}
								alt="Tailwind"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">Tailwind</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/laravel-icon.svg`}
								alt="Laravel"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">Laravel</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/astro-icon.svg`}
								alt="Astro"
								class="w-8 h-8 mb-2"
							/>
							<span class="text-sm">Astro</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- DevOps -->
		<div class="relative w-full h-56 perspective group">
			<!-- Indicador para tocar en mobile -->
			<div
				class="flex sm:hidden items-center gap-1 absolute top-3 right-3 px-2 py-0.5 bg-zinc-900/75 text-white text-xs rounded"
			>
				<svg
					class="w-5 h-5 tap-pulse"
					viewBox="0 0 24 24"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
					aria-hidden="true"
				>
					<path
						d="M17.65 6.35A7.95 7.95 0 0 0 12 4V1L8 5l4 4V6c2.76 0 5 2.24 5 5a5 5 0 0 1-5 5 5 5 0 0 1-4.9-4H5.1A7 7 0 0 0 12 18c3.87 0 7-3.13 7-7 0-1.86-.67-3.56-1.85-4.9z"
					></path>
				</svg>
				<span class="sr-only">Toca para girar</span>
			</div>
			<div
				class="relative w-full h-full transition-transform duration-500 transform-style-preserve-3d group-hover:[transform:rotateY(180deg)]"
			>
				<div
					class="absolute w-full h-full backface-hidden bg-brand.card rounded-xl border border-zinc-700 flex items-center justify-center"
				>
					<h3 class="text-lg font-semibold">DevTools</h3>
				</div>
				<div
					class="absolute w-full h-full [transform:rotateY(180deg)] backface-hidden bg-brand.card rounded-xl border border-brand.accent p-6 flex items-center justify-center"
				>
					<div class="grid grid-cols-2 gap-4 w-full">
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/git-scm-icon.svg`}
								alt="Git"
								class="w-10 h-10 mb-2"
							/>
							<span class="text-sm">Git / GitHub</span>
						</div>
						<div class="flex flex-col items-center">
							<img
								src={`${siteBase}/vitejsdev-icon.svg`}
								alt="Vite"
								class="w-10 h-10 mb-2"
							/>
							<span class="text-sm">Vite</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
