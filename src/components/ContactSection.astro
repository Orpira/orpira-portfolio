---
// src/components/ContactSection.astro
interface Props {
	baseUrl: string;
}

const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";

// Reemplaza con tu Access Key de https://web3forms.com (es gratis)
const WEB3FORMS_KEY = "aa6e8316-5807-4bc6-aa8b-c266d225146a";
---

<section id="contact" class="py-16 section-divider">
	<h3
		class="section-title-contrast font-display font-semibold text-3xl md:text-4xl text-center mb-12"
	>
		Contacto
	</h3>
	<p
		class="text-gray-600 dark:text-brand.muted mb-8 max-w-xl mx-auto text-center"
	>
		¿Tienes un proyecto en mente? <br />Envíame un mensaje y te responderé lo
		antes posible. <br />Disponible para nuevos proyectos, colaboraciones o
		propuestas profesionales. <br />
	</p>
	<!-- <h3 class="text-2xl font-serif font-bold text-brand.accent mb-4">Contacto</h3> -->

	<form id="contact-form" class="max-w-lg mx-auto space-y-5" novalidate>
		<!-- Configuración Web3Forms -->
		<input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
		<input
			type="hidden"
			name="subject"
			value="Nuevo mensaje desde OrPiRa Portfolio"
		/>
		<input
			type="hidden"
			name="from_name"
			value="Orlando Pineda Raad — OrPiRa"
		/>

		<!-- Auto-respuesta al remitente -->
		<input type="hidden" name="autoresponse" value="true" />
		<input
			type="hidden"
			name="autoresponse_subject"
			value="✅ He recibido tu mensaje — Orlando Pineda Raad"
		/>
		<input type="hidden" name="autoresponse_from" value="Orlando Pineda Raad" />
		<input
			type="hidden"
			name="autoresponse_message"
			value="¡Hola! 👋

Gracias por contactarme a través de mi portfolio. He recibido tu mensaje correctamente y lo revisaré lo antes posible.

Te responderé en un plazo máximo de 24-48 horas.

Mientras tanto, puedes revisar mis proyectos en: https://orpira.es

Un cordial saludo,
Orlando Pineda Raad
Desarrollador Full Stack
Bilbao, España"
		/>

		<!-- Anti-spam -->
		<input type="checkbox" name="botcheck" class="hidden" />

		<div>
			<label for="name" class="block text-sm font-medium mb-1 text-left"
				>Nombre</label
			>
			<input
				type="text"
				id="name"
				name="name"
				required
				placeholder="Tu nombre"
				class="w-full px-4 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition"
			/>
		</div>

		<div>
			<label for="email" class="block text-sm font-medium mb-1 text-left"
				>Email</label
			>
			<input
				type="email"
				id="email"
				name="email"
				required
				placeholder="tu@email.com"
				class="w-full px-4 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition"
			/>
		</div>

		<div>
			<label for="message" class="block text-sm font-medium mb-1 text-left"
				>Mensaje</label
			>
			<textarea
				id="message"
				name="message"
				required
				rows="5"
				placeholder="Cuéntame sobre tu proyecto..."
				class="w-full px-4 py-2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none transition resize-none"
			></textarea>
		</div>

		<button
			type="submit"
			id="contact-submit"
			class="w-full py-3 px-6 bg-zinc-900 hover:bg-zinc-800 dark:bg-white dark:hover:bg-zinc-200 text-white dark:text-zinc-900 font-semibold rounded-lg transition-colors focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900 disabled:opacity-50 disabled:cursor-not-allowed"
		>
			Enviar mensaje
		</button>

		<div id="form-status" class="hidden text-center text-sm py-2 rounded-lg">
		</div>
		<p
			id="form-autoresponse-note"
			class="micro-label hidden text-center text-xs text-gray-500 dark:text-gray-400 mt-1"
		>
			📬 Revisa tu bandeja de entrada — recibirás una confirmación automática.
		</p>
	</form>

	<!-- Enlace alternativo para descargar CV -->
	<!-- <div class="mt-8 text-center">
		<a
			href={`${siteBase}/CV_OrlandoPinedaRaad.pdf`}
			download="CV_Orlando_Pineda_Raad.pdf"
			class="inline-flex items-center gap-2 text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white font-medium transition-colors"
		>
			<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
				<path
					d="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z"
				></path>
			</svg>
			Descargar mi CV en PDF
		</a>
	</div> -->
</section>

<script>
	import { createClient } from "@supabase/supabase-js";

	const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
	const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
	const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

	const form = document.getElementById(
		"contact-form",
	) as HTMLFormElement | null;
	const statusDiv = document.getElementById("form-status");
	const submitBtn = document.getElementById(
		"contact-submit",
	) as HTMLButtonElement | null;
	const autoResponseNote = document.getElementById("form-autoresponse-note");

	if (form && statusDiv && submitBtn) {
		form.addEventListener("submit", async (e) => {
			e.preventDefault();

			if (!form.checkValidity()) {
				form.reportValidity();
				return;
			}

			submitBtn.disabled = true;
			submitBtn.textContent = "Enviando...";
			statusDiv.classList.add("hidden");
			if (autoResponseNote) autoResponseNote.classList.add("hidden");

			const name = (form.elements.namedItem("name") as HTMLInputElement).value;
			const email = (form.elements.namedItem("email") as HTMLInputElement)
				.value;
			const message = (
				form.elements.namedItem("message") as HTMLTextAreaElement
			).value;

			try {
				// 1. Enviar a Web3Forms (email + autorespuesta)
				const formData = new FormData(form);
				const web3Promise = fetch("https://api.web3forms.com/submit", {
					method: "POST",
					body: formData,
				});

				// 2. Guardar en Supabase (Dashboard CRM)
				const supaPromise = supabase.from("messages").insert({
					name,
					email,
					message,
					status: "nuevo",
				});

				// Ejecutar ambos en paralelo
				const [web3Res, supaRes] = await Promise.all([
					web3Promise,
					supaPromise,
				]);
				const web3Data = await web3Res.json();

				if (web3Data.success) {
					statusDiv.textContent = "✅ ¡Mensaje enviado! Te responderé pronto.";
					statusDiv.className =
						"text-center text-sm py-2 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400";
					if (autoResponseNote) autoResponseNote.classList.remove("hidden");
					form.reset();

					if (supaRes.error) {
						console.warn("Supabase backup falló:", supaRes.error.message);
					}
				} else {
					statusDiv.textContent = "❌ Error al enviar. Inténtalo de nuevo.";
					statusDiv.className =
						"text-center text-sm py-2 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400";
				}
			} catch {
				statusDiv.textContent = "❌ Error de conexión. Inténtalo más tarde.";
				statusDiv.className =
					"text-center text-sm py-2 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400";
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = "Enviar mensaje";
			}
		});
	}
</script>
