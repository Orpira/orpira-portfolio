---
const baseUrl = import.meta.env.BASE_URL;
const javaIconSrc = `${baseUrl}java-icon.svg`;
---

<section id="services" class="py-20 section-divider">
	<h2
		class="text-3xl md:text-4xl font-serif font-bold text-center mb-12 text-brand.accent"
	>
		Servicios Profesionales
	</h2>
	<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
		<!-- Desarrollo Frontend -->
		<div
			class="p-8 rounded-xl bg-brand.card border border-zinc-700 flex flex-col items-start"
		>
			<span class="mb-4 text-brand.accent"
				>{/** Icono Frontend */}
				<img src={javaIconSrc} alt="Frontend" class="w-8 h-8" />
			</span>
			<h3 class="text-lg font-semibold mb-2">Desarrollo Frontend</h3>
			<p class="text-brand.muted text-sm mb-1">
				Construcción de interfaces modernas con React, TypeScript, Tailwind y
				Astro.
			</p>
			<p class="text-xs text-brand.muted">
				Enfoque en rendimiento, accesibilidad y buenas prácticas.
			</p>
		</div>

		<!-- Soporte IT y soluciones técnicas -->
		<div
			class="p-8 rounded-xl bg-brand.card border border-zinc-700 flex flex-col items-start"
		>
			<span class="mb-4 text-brand.accent"
				>{/** Icono Soporte */}
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="w-8 h-8"
					fill="currentColor"
					viewBox="0 0 48 48"
					><path
						d="M4 1h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zm1 2v2h14V3H5zm-1 6h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1zm1 2v2h14v-2H5zm-1 6h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1zm1 2v2h14v-2H5z"
					></path><circle cx="6" cy="4" r="1"></circle><circle
						cx="6"
						cy="12"
						r="1"></circle><circle cx="6" cy="20" r="1"></circle></svg
				>
			</span>
			<h3 class="text-lg font-semibold mb-2">
				Soporte IT y soluciones técnicas
			</h3>
			<p class="text-brand.muted text-sm mb-1">
				Más de una década resolviendo problemas técnicos, gestionando
				incidencias y acompañando a usuarios.
			</p>
		</div>

		<!-- Automatización y optimización -->
		<div
			class="p-8 rounded-xl bg-brand.card border border-zinc-700 flex flex-col items-start"
		>
			<span class="mb-4 text-brand.accent"
				>{/** Icono Automatización */}
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="w-8 h-8"
					fill="currentColor"
					viewBox="0 0 24 24"
					><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
						d="M22 13.478v4.522a3 3 0 0 1 -3 3h-14a3 3 0 0 1 -3 -3v-4.522l.553 .277a20.999 20.999 0 0 0 18.897 -.002l.55 -.275zm-8 -11.478a3 3 0 0 1 3 3v1h2a3 3 0 0 1 3 3v2.242l-1.447 .724a19.002 19.002 0 0 1 -16.726 .186l-.647 -.32l-1.18 -.59v-2.242a3 3 0 0 1 3 -3h2v-1a3 3 0 0 1 3 -3h4zm-2 8a1 1 0 0 0 -1 1a1 1 0 1 0 2 .01c0 -.562 -.448 -1.01 -1 -1.01zm2 -6h-4a1 1 0 0 0 -1 1v1h6v-1a1 1 0 0 0 -1 -1z"
					></path></svg
				>
			</span>
			<h3 class="text-lg font-semibold mb-2">Automatización y optimización</h3>
			<p class="text-brand.muted text-sm mb-1">
				Creación de flujos eficientes, scripts y herramientas que facilitan el
				trabajo diario.
			</p>
		</div>

		<!-- Acompañamiento tecnológico -->
		<div
			class="p-8 rounded-xl bg-brand.card border border-zinc-700 flex flex-col items-start"
		>
			<span class="mb-4 text-brand.accent"
				>{/** Icono Acompañamiento */}
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="w-8 h-8"
					fill="currentColor"
					viewBox="0 0 24 24"
					><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
						d="M22 7.535v9.465a3 3 0 0 1 -2.824 2.995l-.176 .005h-14a3 3 0 0 1 -2.995 -2.824l-.005 -.176v-9.465l9.445 6.297l.116 .066a1 1 0 0 0 .878 0l.116 -.066l9.445 -6.297z"
					></path><path
						d="M19 4c1.08 0 2.027 .57 2.555 1.427l-9.555 6.37l-9.555 -6.37a2.999 2.999 0 0 1 2.354 -1.42l.201 -.007h14z"
					></path></svg
				>
			</span>
			<h3 class="text-lg font-semibold mb-2">Acompañamiento tecnológico</h3>
			<p class="text-brand.muted text-sm mb-1">
				Asesoría para pequeñas empresas o personas que necesitan orientación
				técnica clara y confiable.
			</p>
		</div>
	</div>
</section>
