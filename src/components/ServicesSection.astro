---
const services = [
	{
		id: "01",
		title: "Arquitectura Frontend",
		focus: "React · Astro · TypeScript",
		summary:
			"Diseño y desarrollo de interfaces con narrativa visual fuerte, performance medible y experiencia de usuario consistente.",
		deliverables: [
			"Sistemas de componentes reutilizables",
			"Optimización de carga y rendimiento",
			"UI responsive con criterio de producto",
		],
	},
	{
		id: "02",
		title: "Plataformas Web Full Stack",
		focus: "Laravel · Node · Supabase",
		summary:
			"Construcción de productos de punta a punta: autenticación, datos, paneles internos y despliegue continuo en Vercel.",
		deliverables: [
			"APIs y flujos de negocio",
			"Paneles de control para operación diaria",
			"Integración de servicios externos",
		],
	},
	{
		id: "03",
		title: "Soporte IT Estratégico",
		focus: "Operaciones · Infra · Automatización",
		summary:
			"Acompañamiento técnico para equipos y empresas que necesitan estabilidad operativa sin frenar la evolución digital.",
		deliverables: [
			"Resolución avanzada de incidencias",
			"Estandarización de procesos técnicos",
			"Documentación y transferencia de conocimiento",
		],
	},
	{
		id: "04",
		title: "Marca Técnica y Posicionamiento",
		focus: "SEO · Contenido · Portafolio",
		summary:
			"Conversión de experiencia técnica en presencia digital: casos, narrativa de valor y ecosistema de proyectos escalable.",
		deliverables: [
			"Estrategia de subdominios por producto",
			"Storytelling de casos reales",
			"Lanzamientos orientados a oportunidad",
		],
	},
];
---

<section id="services" class="py-20 section-divider">
	<div class="text-center mb-12 md:mb-14">
		<p class="editorial-kicker micro-label" data-reveal style="--delay: 40ms;">
			Capacidades de servicio
		</p>
		<h2
			class="section-title-contrast font-display font-semibold text-4xl md:text-5xl mt-3"
			data-reveal
			style="--delay: 120ms;"
		>
			Servicios diseñados para impacto real.
		</h2>
		<!-- <p
			class="mt-4 max-w-3xl mx-auto text-zinc-700 dark:text-brand.muted"
			data-reveal
			style="--delay: 200ms;"
		>
			Combinación de producto, desarrollo y operaciones para construir activos
			digitales que posicionan tu marca y mejoran resultados del negocio.
		</p> -->
	</div>

	<div class="grid lg:grid-cols-2 gap-6">
		{
			services.map((service, index) => (
				<article
					class="service-card sm:col-span-2 col-span-1 p-6 md:p-10 rounded-3xl bg-gradient-to-br from-orange-100/80 to-white shadow-xl border-2 border-orange-300 dark:bg-gradient-to-br dark:from-zinc-900 dark:via-orange-900/40 dark:to-zinc-800 dark:border-orange-500"
					data-reveal
					style={`--delay: ${280 + index * 90}ms;`}
				>
					<div class="flex items-start justify-between gap-4">
						<span class="micro-accent font-mono text-xs uppercase tracking-[0.16em] text-brand.accent">
							{service.id}
						</span>
						<span class="micro-accent text-[0.64rem] uppercase tracking-[0.14em] rounded-full border border-orange-400/60 px-3 py-1 text-orange-700 dark:text-orange-200 bg-orange-100/60 dark:bg-orange-900/40">
							{service.focus}
						</span>
					</div>

					<h3 class="service-card-title font-display text-2xl mt-4 text-orange-800 dark:text-orange-100">
						{service.title}
					</h3>
					<p class="service-card-copy mt-3 text-sm leading-relaxed text-orange-900 dark:text-orange-100">
						{service.summary}
					</p>

					<ul class="service-card-copy mt-5 space-y-2 text-sm">
						{service.deliverables.map((item) => (
							<li class="flex items-start gap-2">
								<span
									class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brand.accent"
									aria-hidden="true"
								/>
								<span>{item}</span>
							</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</section>
