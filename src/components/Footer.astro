---
import Github from "./icons/Github.astro";
import LinkedIn from "./icons/LinkedIn.astro";
import Email from "./icons/Email.astro";
import Location from "./icons/Location.astro";
---

<footer id="contact" class="mt-12 py-12 border-t border-zinc-800 text-center">
	<h3 class="text-2xl font-serif font-bold text-brand.accent mb-4">Contacto</h3>

	<p
		class="text-gray-600 dark:text-brand.muted mb-6 max-w-xl mx-auto text-justify"
	>
		Estoy disponible para nuevos proyectos, colaboraciones o propuestas
		profesionales. Puedes contactarme directamente a través de los siguientes
		medios:
	</p>

	<div class="flex justify-center gap-8 mb-8">
		<a
			id="footer-email"
			href="#"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
		>
			<Email />
		</a>
		<a
			href="https://www.linkedin.com/in/orlando-pineda-raad-273402257"
			target="_blank"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
		>
			<LinkedIn />
		</a>
		<a
			href="https://github.com/Orpira"
			target="_blank"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
		>
			<Github />
		</a>
	</div>

	<p class="text-xs text-gray-600 dark:text-brand.muted">
		{new Date().getFullYear()} Orlando Pineda Raad.
	</p>

	<p
		class="text-sm text-gray-600 dark:text-brand.muted mt-2 flex items-center justify-center gap-2"
	>
		<Location class="w-5 h-5" />
		Bilbao, España
	</p>
</footer>

<script>
	const _fe = document.getElementById("footer-email") as HTMLAnchorElement | null;
	if (_fe) _fe.href = "mailto:" + atob("b3JwaXJhQGljbG91ZC5jb20=");
</script>
