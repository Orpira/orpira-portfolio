---
import Github from "./icons/Github.astro";
import LinkedIn from "./icons/LinkedIn.astro";
import Email from "./icons/Email.astro";
import Location from "./icons/Location.astro";
---

<footer id="contact" class="mt-12 py-12 section-divider text-center">
	<p
		class="text-gray-600 dark:text-brand.muted mb-6 max-w-xl mx-auto text-justify"
	>
		Puedes contactarme directamente a través de los siguientes medios:
	</p>

	<div class="flex justify-center gap-8 mb-8">
		<a
			href="#contact"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
			title="Formulario de contacto"
		>
			<Email />
		</a>
		<a
			href="https://www.linkedin.com/in/orlando-pineda-raad-273402257"
			target="_blank"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
		>
			<LinkedIn />
		</a>
		<a
			href="https://github.com/Orpira"
			target="_blank"
			class="flex flex-col items-center text-gray-600 dark:text-brand.muted hover:text-brand.accent transition"
		>
			<Github />
		</a>
	</div>

	<div class="max-w-2xl mx-auto mb-8">
		<p
			class="micro-label text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-brand.muted"
		>
			Ecosistema Orpira
		</p>
		<div class="mt-3 flex flex-wrap justify-center gap-3 text-sm">
			<a
				href="https://orpira.es"
				target="_blank"
				rel="noopener noreferrer"
				class="px-3 py-1 rounded-full border border-zinc-300 dark:border-zinc-700 hover:border-brand.accent hover:text-brand.accent transition"
			>
				Orpira.es (Landing + Portfolio)
			</a>
			<a
				href="https://portfolio.orpira.es"
				target="_blank"
				rel="noopener noreferrer"
				class="px-3 py-1 rounded-full border border-zinc-300 dark:border-zinc-700 hover:border-brand.accent hover:text-brand.accent transition"
			>
				Alias Portfolio
			</a>
			<a
				href="https://lab.orpira.es"
				target="_blank"
				rel="noopener noreferrer"
				class="px-3 py-1 rounded-full border border-zinc-300 dark:border-zinc-700 hover:border-brand.accent hover:text-brand.accent transition"
			>
				Lab
			</a>
			<a
				href="https://api.orpira.es"
				target="_blank"
				rel="noopener noreferrer"
				class="px-3 py-1 rounded-full border border-zinc-300 dark:border-zinc-700 hover:border-brand.accent hover:text-brand.accent transition"
			>
				API
			</a>
		</div>
	</div>

	<p class="micro-label text-xs text-gray-600 dark:text-brand.muted">
		{new Date().getFullYear()} Orlando Pineda Raad.
	</p>

	<p
		class="text-sm text-gray-600 dark:text-brand.muted mt-2 flex items-center justify-center gap-2"
	>
		<Location class="w-5 h-5" />
		Bilbao, España
	</p>
</footer>
