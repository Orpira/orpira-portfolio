---
const { title = "Orpira - Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- Tipografías -->
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Merriweather:wght@700&display=swap"
			rel="stylesheet"
		/>

		<style>
			body {
				background-color: #0d1117;
				color: #e6eaf2;
			}
		</style>

		<script>
			// Evitar flash al cargar la página
			if (
				localStorage.theme === "dark" ||
				(!("theme" in localStorage) &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>

	<body class="font-sans leading-relaxed antialiased">
		<main class="max-w-6xl mx-auto px-4">
			<slot />
		</main>
	</body>
</html>
