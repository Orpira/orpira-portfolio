---
import "../styles/global.css";

interface Props {
  title?: string;
}

const {
  title = "CRM OrPiRa",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>
</head>

<body class="bg-slate-950 text-slate-100">

<div class="flex min-h-screen">

  <!-- Sidebar -->

  <aside
    class="w-64 bg-slate-900 border-r border-slate-800"
  >

    <div class="p-6 border-b border-slate-800">

      <h1 class="text-2xl font-bold">
        CRM OrPiRa
      </h1>

      <p class="text-slate-400 text-sm">
        Lead Management
      </p>

    </div>

    <nav class="p-4 space-y-2">

      <a
        href="/dashboard/leads"
        class="block px-4 py-3 rounded-lg hover:bg-slate-800"
      >
        📊 Dashboard
      </a>

      <a
        href="/dashboard/leads"
        class="block px-4 py-3 rounded-lg hover:bg-slate-800"
      >
        👥 Leads
      </a>

      <a
        href="/dashboard/clientes"
        class="block px-4 py-3 rounded-lg hover:bg-slate-800"
        >
        ⭐ Clientes
        </a>

      <a
        href="#"
        class="block px-4 py-3 rounded-lg hover:bg-slate-800"
      >
        📈 Reportes
      </a>

      <a
        href="#"
        class="block px-4 py-3 rounded-lg hover:bg-slate-800"
      >
        ⚙️ Configuración
      </a>

    </nav>

  

    <a
        href="/dashboard/logout"
        class="
            flex
            items-center
            gap-3
            p-4
            rounded-xl
            bg-red-500/10
            border
            border-red-500/20
            hover:bg-red-500/20
            transition-all
            duration-300
            text-red-400
            hover:text-red-300
        "
        >
        <span class="text-xl">
            🚪
        </span>

        <div>
            <p class="font-semibold">
            Salir
            </p>

            <p class="text-xs opacity-70">
            Cerrar sesión
            </p>
        </div>
    </a>

    

  </aside>

  <!-- Contenido -->

  <main class="flex-1 p-8">
    <slot />
  </main>

</div>

</body>
</html>