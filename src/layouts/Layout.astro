---
import "../styles/global.css";

interface Props {
	baseUrl: string;
}

const { baseUrl } = Astro.props;
const siteBase = baseUrl ?? "";
const pageTitle = "OrPiRa | Portfolio";
const description =
	"Portfolio profesional de Orlando Pineda Raad (OrPiRa): proyectos, servicios y experiencia en ingenieria informatica.";
const canonical = Astro.site
	? new URL(Astro.url.pathname, Astro.site).toString()
	: Astro.url.toString();
const ogImage = Astro.site
	? new URL(`${siteBase}/opr.png`, Astro.site).toString()
	: `${siteBase}/opr.png`;
---

<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="icon" type="image/png" href={`${siteBase}/opr.png`} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,500&family=JetBrains+Mono:wght@400;600&family=Manrope:wght@400;500;600;700;800&family=Syne:wght@400;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<script>
			if (
				localStorage.theme === "dark" ||
				(!("theme" in localStorage) &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>

	<body
		class="relative bg-zinc-100 dark:bg-brand.bg text-zinc-900 dark:text-brand.text font-sans selection:bg-brand.accent/30 selection:text-brand.text"
	>
		<div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10">
			<div
				class="absolute -top-28 left-[18%] h-72 w-72 rounded-full bg-brand.accent/20 blur-3xl"
			>
			</div>
			<div
				class="absolute top-40 -right-16 h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"
			>
			</div>
			<div
				class="absolute -bottom-16 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-rose-300/10 blur-3xl"
			>
			</div>
		</div>

		<header
			class="fixed inset-x-0 top-0 z-50 border-b border-black/10 dark:border-white/10 bg-white/70 dark:bg-brand.bg/70 backdrop-blur-xl"
		>
			<nav
				class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center"
			>
				<div>
					<a href="#top" class="flex items-center gap-3">
						<img
							src={`${siteBase}/orpira.png`}
							alt="OrPiRa"
							class="size-11 rounded-full border-2 border-black shadow-sm"
						/>
						
						<span
							class="font-display text-3xl font-semibold tracking-tight text-zinc-900 dark:text-brand.text"
						>
							OrPiRa
						</span>
					</a>
					<!-- <p
						class="micro-label nav-subtitle hidden md:block text-[0.62rem] uppercase tracking-[0.24em] mt-1"
					>
						Marca personal digital
					</p> -->
				</div>

				<ul
					class="micro-label hidden md:flex items-center gap-5 text-[0.72rem] uppercase tracking-[0.2em]"
				>
					<li>
						<a href="#top" class="nav-title-link">Inicio</a>
					</li>
					<li>
						<a href="#skills" class="nav-title-link">Servicios</a>
					</li>
					<li>
						<a href="#projects" class="nav-title-link">Proyectos</a>
					</li>					
					<li>
						<a href="#contact" class="nav-title-link">Contacto</a>
					</li>
				</ul>

				<div class="flex items-center gap-2">
					<button
						id="theme-toggle"
						class="border border-black/15 dark:border-white/15 px-3 py-2 rounded-full hover:bg-zinc-100/80 dark:hover:bg-white/10 transition-colors"
						aria-label="Cambiar tema"
					>
						<svg
							id="sun-icon"
							class="w-5 h-5 hidden dark:block"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								fill-rule="evenodd"
								d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
								clip-rule="evenodd"></path>
						</svg>
						<svg
							id="moon-icon"
							class="w-5 h-5 block dark:hidden"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
							></path>
						</svg>
					</button>

					<button
						id="mobile-menu-button"
						class="md:hidden p-2 rounded-full border border-black/15 dark:border-white/15 hover:bg-zinc-100/80 dark:hover:bg-white/10 transition-colors"
						aria-label="Abrir menu"
					>
						<svg
							id="hamburger-icon"
							class="w-6 h-6"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
						<svg
							id="close-icon"
							class="w-6 h-6 hidden"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M6 18L18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
			</nav>

			<div
				id="mobile-menu"
				class="md:hidden hidden border-t border-black/10 dark:border-white/10 bg-white/90 dark:bg-brand.card/90 backdrop-blur-xl"
			>
				<ul
					class="micro-label px-4 py-4 space-y-3 text-xs uppercase tracking-[0.2em]"
				>
					<li>
						<a href="#top" class="nav-title-link block py-2 mobile-menu-link"
							>Inicio</a
						>
					</li>
					<li>
						<a
							href="#skills"
							class="nav-title-link block py-2 mobile-menu-link">Servicios</a
						>
					</li>
					<li>
						<a
							href="#projects"
							class="nav-title-link block py-2 mobile-menu-link">Proyectos</a
						>
					</li>
					<li>
						<a
							href="#contact"
							class="nav-title-link block py-2 mobile-menu-link">Contacto</a
						>
					</li>
				</ul>
			</div>
		</header>

		<main class="pt-0 pb-28 max-w-6xl mx-auto px-4 md:px-6">
			<slot />
		</main>

		<a
			href="https://wa.me/34643684541"
			target="_blank"
			rel="noopener noreferrer"
			class="fixed bottom-6 right-6 z-50 transition-all duration-300 flex items-center justify-center rounded-full border border-white/20 bg-brand.card/80 p-2 backdrop-blur"
			aria-label="WhatsApp"
		>
			<img
				src={`${siteBase}/whatsapp-icon.svg`}
				alt="WhatsApp"
				class="size-8 icono-borde-blanco"
			/>
		</a>

		<button
			id="scroll-top-btn"
			class="fixed bottom-6 left-6 z-50 hidden w-10 h-10 rounded-full border border-black/10 dark:border-white/20 bg-white/70 dark:bg-brand.card/85 text-zinc-900 dark:text-brand.text shadow-lg items-center justify-center transition-all duration-300 hover:scale-110 opacity-0"
			aria-label="Ir arriba"
		>
			<svg
				class="w-5 h-5"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M5 15l7-7 7 7"></path>
			</svg>
		</button>

		<script>
			const BRAND_METRICS_KEY = "orpira_brand_metrics_v1";
			const BRAND_SESSION_KEY = "orpira_brand_session_id";

			const trackBrandMetrics = () => {
				try {
					const rawMetrics = localStorage.getItem(BRAND_METRICS_KEY);
					const metrics = rawMetrics
						? JSON.parse(rawMetrics)
						: { views: [], sessions: [] };

					let sessionId = sessionStorage.getItem(BRAND_SESSION_KEY);
					if (!sessionId) {
						sessionId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
						sessionStorage.setItem(BRAND_SESSION_KEY, sessionId);
					}

					if (!Array.isArray(metrics.sessions)) metrics.sessions = [];
					if (!Array.isArray(metrics.views)) metrics.views = [];

					const hasSession = metrics.sessions.some(
						(session: { id?: string }) => session.id === sessionId,
					);
					if (!hasSession) {
						metrics.sessions.push({
							id: sessionId,
							startedAt: new Date().toISOString(),
						});
					}

					metrics.views.push({
						path: window.location.pathname || "/",
						at: new Date().toISOString(),
						sessionId,
					});

					if (metrics.views.length > 2000) {
						metrics.views = metrics.views.slice(-2000);
					}
					if (metrics.sessions.length > 500) {
						metrics.sessions = metrics.sessions.slice(-500);
					}

					localStorage.setItem(BRAND_METRICS_KEY, JSON.stringify(metrics));
				} catch (error) {
					console.warn("No se pudo registrar metricas locales de marca", error);
				}
			};

			trackBrandMetrics();

			const scrollTopBtn = document.getElementById("scroll-top-btn");
			if (scrollTopBtn) {
				window.addEventListener("scroll", () => {
					if (window.scrollY > 300) {
						scrollTopBtn.classList.remove("hidden");
						scrollTopBtn.classList.add("flex");
						requestAnimationFrame(() => {
							scrollTopBtn.style.opacity = "1";
						});
					} else {
						scrollTopBtn.style.opacity = "0";
						setTimeout(() => {
							scrollTopBtn.classList.add("hidden");
							scrollTopBtn.classList.remove("flex");
						}, 300);
					}
				});
				scrollTopBtn.addEventListener("click", () => {
					window.scrollTo({ top: 0, behavior: "smooth" });
				});
			}

			const themeToggle = document.getElementById("theme-toggle");
			if (themeToggle) {
				themeToggle.addEventListener("click", () => {
					const html = document.documentElement;
					html.classList.toggle("dark");
					localStorage.theme = html.classList.contains("dark")
						? "dark"
						: "light";
				});
			}

			const mobileMenuButton = document.getElementById("mobile-menu-button");
			const mobileMenu = document.getElementById("mobile-menu");
			const hamburgerIcon = document.getElementById("hamburger-icon");
			const closeIcon = document.getElementById("close-icon");

			if (mobileMenuButton && mobileMenu && hamburgerIcon && closeIcon) {
				mobileMenuButton.addEventListener("click", () => {
					const isMenuOpen = !mobileMenu.classList.contains("hidden");
					mobileMenu.classList.toggle("hidden");

					if (isMenuOpen) {
						hamburgerIcon.classList.remove("hidden");
						closeIcon.classList.add("hidden");
						mobileMenuButton.setAttribute("aria-label", "Abrir menu");
					} else {
						hamburgerIcon.classList.add("hidden");
						closeIcon.classList.remove("hidden");
						mobileMenuButton.setAttribute("aria-label", "Cerrar menu");
					}
				});

				const mobileMenuLinks = document.querySelectorAll(".mobile-menu-link");
				mobileMenuLinks.forEach((link) => {
					link.addEventListener("click", () => {
						mobileMenu.classList.add("hidden");
						hamburgerIcon.classList.remove("hidden");
						closeIcon.classList.add("hidden");
						mobileMenuButton.setAttribute("aria-label", "Abrir menu");
					});
				});

				window.addEventListener("resize", () => {
					if (window.innerWidth >= 768) {
						mobileMenu.classList.add("hidden");
						hamburgerIcon.classList.remove("hidden");
						closeIcon.classList.add("hidden");
						mobileMenuButton.setAttribute("aria-label", "Abrir menu");
					}
				});
			}
		</script>
	</body>
</html>
